let wad_data = []
let wad_lumps = []
let wad_numlumps = 0

func wad_open(path) {
    wad_data = fs_read_bytes(path)
    if wad_data == null || len(wad_data) < 12 {
        println(f"ERROR: Cannot read WAD file: {path}")
        return false
    }
    const id = chr(wad_data[0]) + chr(wad_data[1]) + chr(wad_data[2]) + chr(wad_data[3])
    if id != "IWAD" && id != "PWAD" {
        println(f"ERROR: Not a WAD file (got {id})")
        return false
    }
    wad_numlumps = read_i32(wad_data, 4)
    const infotableofs = read_i32(wad_data, 8)
    wad_lumps = []
    let i = 0
    while i < wad_numlumps {
        const ofs = infotableofs + i * 16
        const filepos = read_i32(wad_data, ofs)
        const size = read_i32(wad_data, ofs + 4)
        let name = ""
        let j = 0
        while j < 8 {
            const c = wad_data[ofs + 8 + j]
            if c == 0 { j = 8 } else { name = name + chr(c) }
            j = j + 1
        }
        wad_lumps.push({"name": name.upper(), "filepos": filepos, "size": size, "index": i})
        i = i + 1
    }
    println(f"WAD loaded: {id}, {wad_numlumps} lumps")
    true
}

func wad_find(name) {
    const uname = name.upper()
    let i = wad_numlumps - 1
    while i >= 0 {
        if wad_lumps[i]["name"] == uname { return i }
        i = i - 1
    }
    -1
}

func wad_find_after(name, after) {
    const uname = name.upper()
    let i = after + 1
    while i < wad_numlumps {
        if wad_lumps[i]["name"] == uname { return i }
        i = i + 1
    }
    -1
}

func wad_read(index) {
    if index < 0 || index >= wad_numlumps { return [] }
    const lump = wad_lumps[index]
    const start = lump["filepos"]
    const sz = lump["size"]
    let result = []
    let i = 0
    while i < sz {
        result.push(wad_data[start + i])
        i = i + 1
    }
    result
}

func wad_lump_size(index) {
    if index < 0 || index >= wad_numlumps { return 0 }
    wad_lumps[index]["size"]
}

func wad_lump_name(index) {
    if index < 0 || index >= wad_numlumps { return "" }
    wad_lumps[index]["name"]
}

func read_i16(data, offset) {
    if offset + 1 >= len(data) { return 0 }
    let val = data[offset] | (data[offset + 1] << 8)
    if val >= 32768 { val = val - 65536 }
    val
}

func read_u16(data, offset) {
    if offset + 1 >= len(data) { return 0 }
    data[offset] | (data[offset + 1] << 8)
}

func read_i32(data, offset) {
    if offset + 3 >= len(data) { return 0 }
    let val = data[offset] | (data[offset + 1] << 8) | (data[offset + 2] << 16) | (data[offset + 3] << 24)
    val
}

func read_string(data, offset, maxlen) {
    let s = ""
    let i = 0
    while i < maxlen {
        if offset + i >= len(data) { return s }
        const c = data[offset + i]
        if c == 0 { return s }
        s = s + chr(c)
        i = i + 1
    }
    s
}

func chr(code) {
    if code >= 65 && code <= 90 { return char_at("ABCDEFGHIJKLMNOPQRSTUVWXYZ", code - 65) }
    if code >= 97 && code <= 122 { return char_at("abcdefghijklmnopqrstuvwxyz", code - 97) }
    if code >= 48 && code <= 57 { return char_at("0123456789", code - 48) }
    if code == 32 { return " " }
    if code == 45 { return "-" }
    if code == 95 { return "_" }
    if code == 46 { return "." }
    if code == 47 { return "/" }
    "?"
}

func wad_find_map_lump(episode, mission, lumpname) {
    const mapname = f"E{episode}M{mission}"
    const map_idx = wad_find(mapname)
    if map_idx < 0 { return -1 }
    wad_find_after(lumpname, map_idx)
}

func wad_find_flat_range() {
    const f_start = wad_find("F_START")
    const f_end = wad_find("F_END")
    if f_start < 0 || f_end < 0 { return {"start": -1, "end": -1} }
    {"start": f_start, "end": f_end}
}

func wad_find_sprite_range() {
    const s_start = wad_find("S_START")
    const s_end = wad_find("S_END")
    if s_start < 0 || s_end < 0 { return {"start": -1, "end": -1} }
    {"start": s_start, "end": s_end}
}

func wad_find_between(start_name, end_name) {
    const s = wad_find(start_name)
    const e = wad_find(end_name)
    if s < 0 || e < 0 { return [] }
    let result = []
    let i = s + 1
    while i < e {
        result.push(i)
        i = i + 1
    }
    result
}

func fs_read_bytes(path) {
    const raw = fs_read(path)
    if raw == null { return null }
    let bytes = []
    let i = 0
    while i < len(raw) {
        bytes.push(char_code_at(raw, i))
        i = i + 1
    }
    bytes
}

func char_code_at(s, i) {
    if i >= len(s) { return 0 }
    const c = s.char_at(i)
    if c == "" { return 0 }
    to_byte(c)
}

func to_byte(c) {
    const chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}"
    let i = 0
    while i < len(chars) {
        if chars.char_at(i) == c { return 32 + i }
        i = i + 1
    }
    0
}
let map_vertexes = []
let map_linedefs = []
let map_sidedefs = []
let map_sectors = []
let map_segs = []
let map_subsectors = []
let map_nodes = []
let map_things = []
let map_blockmap = null
let map_reject = []
let map_num_sectors = 0
let map_num_lines = 0
let map_num_sides = 0
let map_num_segs = 0
let map_num_subsectors = 0
let map_num_nodes = 0
let map_num_vertexes = 0
let map_num_things = 0

func map_load(episode, mission) {
    map_load_vertexes(episode, mission)
    map_load_sectors(episode, mission)
    map_load_sidedefs(episode, mission)
    map_load_linedefs(episode, mission)
    map_load_segs(episode, mission)
    map_load_subsectors(episode, mission)
    map_load_nodes(episode, mission)
    map_load_things(episode, mission)
    map_load_blockmap(episode, mission)
    map_load_reject(episode, mission)
    println(f"Map E{episode}M{mission}: {map_num_vertexes} verts, {map_num_linedefs} lines, {map_num_sectors} sectors, {map_num_nodes} nodes, {map_num_things} things")
}

func map_load_vertexes(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "VERTEXES")
    if idx < 0 { println("ERROR: VERTEXES not found"); return }
    const data = wad_read(idx)
    map_vertexes = []
    map_num_vertexes = len(data) / 4
    let i = 0
    while i < map_num_vertexes {
        const ofs = i * 4
        const x = read_i16(data, ofs) << FRACBITS
        const y = read_i16(data, ofs + 2) << FRACBITS
        map_vertexes.push({"x": x, "y": y})
        i = i + 1
    }
}

func map_load_sectors(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "SECTORS")
    if idx < 0 { println("ERROR: SECTORS not found"); return }
    const data = wad_read(idx)
    map_sectors = []
    map_num_sectors = len(data) / 26
    let i = 0
    while i < map_num_sectors {
        const ofs = i * 26
        map_sectors.push({
            "floorheight": read_i16(data, ofs) << FRACBITS,
            "ceilingheight": read_i16(data, ofs + 2) << FRACBITS,
            "floorpic": read_string(data, ofs + 4, 8).upper(),
            "ceilingpic": read_string(data, ofs + 12, 8).upper(),
            "lightlevel": read_i16(data, ofs + 20),
            "special": read_i16(data, ofs + 22),
            "tag": read_i16(data, ofs + 24),
            "soundtraversed": 0,
            "soundtarget": null,
            "thinglist": null,
            "floordata": null,
            "ceilingdata": null,
            "validcount": 0,
            "lines": [],
            "index": i
        })
        i = i + 1
    }
}

func map_load_sidedefs(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "SIDEDEFS")
    if idx < 0 { println("ERROR: SIDEDEFS not found"); return }
    const data = wad_read(idx)
    map_sidedefs = []
    map_num_sides = len(data) / 30
    let i = 0
    while i < map_num_sides {
        const ofs = i * 30
        const sector_idx = read_i16(data, ofs + 28)
        map_sidedefs.push({
            "textureoffset": read_i16(data, ofs) << FRACBITS,
            "rowoffset": read_i16(data, ofs + 2) << FRACBITS,
            "toptexture": read_string(data, ofs + 4, 8).upper(),
            "bottomtexture": read_string(data, ofs + 12, 8).upper(),
            "midtexture": read_string(data, ofs + 20, 8).upper(),
            "sector": if sector_idx >= 0 && sector_idx < map_num_sectors { map_sectors[sector_idx] } else { null },
            "sector_idx": sector_idx
        })
        i = i + 1
    }
}

func map_load_linedefs(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "LINEDEFS")
    if idx < 0 { println("ERROR: LINEDEFS not found"); return }
    const data = wad_read(idx)
    map_linedefs = []
    map_num_linedefs = len(data) / 14
    let i = 0
    while i < map_num_linedefs {
        const ofs = i * 14
        const v1 = read_u16(data, ofs)
        const v2 = read_u16(data, ofs + 2)
        const flags = read_i16(data, ofs + 4)
        const special = read_i16(data, ofs + 6)
        const tag = read_i16(data, ofs + 8)
        const s1 = read_u16(data, ofs + 10)
        const s2 = read_u16(data, ofs + 12)
        const vertex1 = if v1 < map_num_vertexes { map_vertexes[v1] } else { {"x": 0, "y": 0} }
        const vertex2 = if v2 < map_num_vertexes { map_vertexes[v2] } else { {"x": 0, "y": 0} }
        const dx = vertex2["x"] - vertex1["x"]
        const dy = vertex2["y"] - vertex1["y"]
        const front = if s1 < map_num_sides && s1 != 65535 { map_sidedefs[s1] } else { null }
        const back = if s2 < map_num_sides && s2 != 65535 { map_sidedefs[s2] } else { null }
        map_linedefs.push({
            "v1": vertex1, "v2": vertex2,
            "dx": dx, "dy": dy,
            "flags": flags, "special": special, "tag": tag,
            "sidenum": [s1, s2],
            "frontsector": if front != null { front["sector"] } else { null },
            "backsector": if back != null { back["sector"] } else { null },
            "front": front, "back": back,
            "validcount": 0,
            "bbox": {
                "top": if vertex1["y"] > vertex2["y"] { vertex1["y"] } else { vertex2["y"] },
                "bottom": if vertex1["y"] < vertex2["y"] { vertex1["y"] } else { vertex2["y"] },
                "left": if vertex1["x"] < vertex2["x"] { vertex1["x"] } else { vertex2["x"] },
                "right": if vertex1["x"] > vertex2["x"] { vertex1["x"] } else { vertex2["x"] }
            },
            "slopetype": if dx == 0 { 0 } else if dy == 0 { 1 } else if (dy > 0) == (dx > 0) { 2 } else { 3 },
            "index": i
        })
        i = i + 1
    }
}

func map_load_segs(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "SEGS")
    if idx < 0 { println("ERROR: SEGS not found"); return }
    const data = wad_read(idx)
    map_segs = []
    map_num_segs = len(data) / 12
    let i = 0
    while i < map_num_segs {
        const ofs = i * 12
        const v1 = read_u16(data, ofs)
        const v2 = read_u16(data, ofs + 2)
        const angle = read_i16(data, ofs + 4) << 16
        const linedef_idx = read_u16(data, ofs + 6)
        const side = read_i16(data, ofs + 8)
        const offset = read_i16(data, ofs + 10) << FRACBITS
        const ld = if linedef_idx < map_num_linedefs { map_linedefs[linedef_idx] } else { null }
        const sidedef = if ld != null {
            if side == 0 { ld["front"] } else { ld["back"] }
        } else { null }
        const frontsector = if sidedef != null { sidedef["sector"] } else { null }
        const backsector = if ld != null {
            if side == 0 { ld["backsector"] } else { ld["frontsector"] }
        } else { null }
        map_segs.push({
            "v1": if v1 < map_num_vertexes { map_vertexes[v1] } else { {"x": 0, "y": 0} },
            "v2": if v2 < map_num_vertexes { map_vertexes[v2] } else { {"x": 0, "y": 0} },
            "angle": angle,
            "linedef": ld,
            "side": side,
            "offset": offset,
            "sidedef": sidedef,
            "frontsector": frontsector,
            "backsector": backsector
        })
        i = i + 1
    }
}

func map_load_subsectors(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "SSECTORS")
    if idx < 0 { println("ERROR: SSECTORS not found"); return }
    const data = wad_read(idx)
    map_subsectors = []
    map_num_subsectors = len(data) / 4
    let i = 0
    while i < map_num_subsectors {
        const ofs = i * 4
        map_subsectors.push({
            "numlines": read_u16(data, ofs),
            "firstline": read_u16(data, ofs + 2),
            "sector": null
        })
        i = i + 1
    }
    i = 0
    while i < map_num_subsectors {
        const ss = map_subsectors[i]
        if ss["firstline"] < map_num_segs {
            const seg = map_segs[ss["firstline"]]
            ss["sector"] = seg["frontsector"]
        }
        i = i + 1
    }
}

func map_load_nodes(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "NODES")
    if idx < 0 { println("ERROR: NODES not found"); return }
    const data = wad_read(idx)
    map_nodes = []
    map_num_nodes = len(data) / 28
    let i = 0
    while i < map_num_nodes {
        const ofs = i * 28
        map_nodes.push({
            "x": read_i16(data, ofs) << FRACBITS,
            "y": read_i16(data, ofs + 2) << FRACBITS,
            "dx": read_i16(data, ofs + 4) << FRACBITS,
            "dy": read_i16(data, ofs + 6) << FRACBITS,
            "bbox": [
                {
                    "top": read_i16(data, ofs + 8) << FRACBITS,
                    "bottom": read_i16(data, ofs + 10) << FRACBITS,
                    "left": read_i16(data, ofs + 12) << FRACBITS,
                    "right": read_i16(data, ofs + 14) << FRACBITS
                },
                {
                    "top": read_i16(data, ofs + 16) << FRACBITS,
                    "bottom": read_i16(data, ofs + 18) << FRACBITS,
                    "left": read_i16(data, ofs + 20) << FRACBITS,
                    "right": read_i16(data, ofs + 22) << FRACBITS
                }
            ],
            "children": [read_u16(data, ofs + 24), read_u16(data, ofs + 26)]
        })
        i = i + 1
    }
}

func map_load_things(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "THINGS")
    if idx < 0 { println("ERROR: THINGS not found"); return }
    const data = wad_read(idx)
    map_things = []
    map_num_things = len(data) / 10
    let i = 0
    while i < map_num_things {
        const ofs = i * 10
        map_things.push({
            "x": read_i16(data, ofs) << FRACBITS,
            "y": read_i16(data, ofs + 2) << FRACBITS,
            "angle": read_i16(data, ofs + 4),
            "type": read_u16(data, ofs + 6),
            "options": read_i16(data, ofs + 8)
        })
        i = i + 1
    }
}

func map_load_blockmap(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "BLOCKMAP")
    if idx < 0 { map_blockmap = null; return }
    const data = wad_read(idx)
    if len(data) < 8 { map_blockmap = null; return }
    map_blockmap = {
        "originx": read_i16(data, 0) << FRACBITS,
        "originy": read_i16(data, 2) << FRACBITS,
        "width": read_i16(data, 4),
        "height": read_i16(data, 6),
        "data": data
    }
}

func map_load_reject(ep, mi) {
    const idx = wad_find_map_lump(ep, mi, "REJECT")
    if idx < 0 { map_reject = []; return }
    map_reject = wad_read(idx)
}

func map_check_reject(s1, s2) {
    if len(map_reject) == 0 { return false }
    const bit = s1 * map_num_sectors + s2
    const byte_idx = bit / 8
    const bit_idx = bit & 7
    if byte_idx >= len(map_reject) { return false }
    (map_reject[byte_idx] & (1 << bit_idx)) != 0
}

func map_get_subsector(x, y) {
    let node_idx = map_num_nodes - 1
    while node_idx < 32768 {
        const node = map_nodes[node_idx]
        const side = point_on_side(x, y, node["x"], node["y"], node["dx"], node["dy"])
        node_idx = node["children"][side]
    }
    node_idx & 32767
}
let tex_palette = []
let tex_colormaps = []
let tex_textures = []
let tex_flats = {}
let tex_patches = {}
let tex_pnames = []
let tex_texture_cache = {}
let tex_flat_cache = {}
let tex_sprite_lumps = {}

func texture_init() {
    texture_load_palette()
    texture_load_colormaps()
    texture_load_pnames()
    texture_load_textures()
    texture_index_flats()
    texture_index_sprites()
}

func texture_load_palette() {
    const idx = wad_find("PLAYPAL")
    if idx < 0 { println("ERROR: PLAYPAL not found"); return }
    const data = wad_read(idx)
    tex_palette = []
    let i = 0
    while i < 256 {
        const ofs = i * 3
        tex_palette.push({"r": data[ofs], "g": data[ofs + 1], "b": data[ofs + 2]})
        i = i + 1
    }
}

func texture_load_colormaps() {
    const idx = wad_find("COLORMAP")
    if idx < 0 { println("ERROR: COLORMAP not found"); return }
    const data = wad_read(idx)
    tex_colormaps = []
    let m = 0
    while m < 34 {
        let cmap = []
        let i = 0
        while i < 256 {
            cmap.push(data[m * 256 + i])
            i = i + 1
        }
        tex_colormaps.push(cmap)
        m = m + 1
    }
}

func texture_load_pnames() {
    const idx = wad_find("PNAMES")
    if idx < 0 { println("ERROR: PNAMES not found"); return }
    const data = wad_read(idx)
    const count = read_i32(data, 0)
    tex_pnames = []
    let i = 0
    while i < count {
        tex_pnames.push(read_string(data, 4 + i * 8, 8).upper())
        i = i + 1
    }
}

func texture_load_textures() {
    tex_textures = []
    const lump_names = ["TEXTURE1", "TEXTURE2"]
    for lname in lump_names {
        const idx = wad_find(lname)
        if idx < 0 { continue }
        const data = wad_read(idx)
        const numtextures = read_i32(data, 0)
        let i = 0
        while i < numtextures {
            const offset = read_i32(data, 4 + i * 4)
            const name = read_string(data, offset, 8).upper()
            const width = read_u16(data, offset + 12)
            const height = read_u16(data, offset + 14)
            const patchcount = read_u16(data, offset + 20)
            let patches = []
            let p = 0
            while p < patchcount {
                const pofs = offset + 22 + p * 10
                patches.push({
                    "originx": read_i16(data, pofs),
                    "originy": read_i16(data, pofs + 2),
                    "patch": read_u16(data, pofs + 4)
                })
                p = p + 1
            }
            tex_textures.push({
                "name": name,
                "width": width,
                "height": height,
                "patches": patches
            })
            i = i + 1
        }
    }
    println(f"Loaded {len(tex_textures)} textures")
}

func texture_index_flats() {
    const range = wad_find_flat_range()
    if range["start"] < 0 { return }
    let i = range["start"] + 1
    while i < range["end"] {
        const name = wad_lump_name(i)
        if wad_lump_size(i) == 4096 {
            tex_flats[name] = i
        }
        i = i + 1
    }
    println(f"Indexed {len(tex_flats)} flats")
}

func texture_index_sprites() {
    const range = wad_find_sprite_range()
    if range["start"] < 0 { return }
    let i = range["start"] + 1
    while i < range["end"] {
        const name = wad_lump_name(i)
        tex_sprite_lumps[name] = i
        i = i + 1
    }
    println(f"Indexed {len(tex_sprite_lumps)} sprite lumps")
}

func texture_find(name) {
    const uname = name.upper()
    if uname == "-" || uname == "" { return null }
    let i = 0
    while i < len(tex_textures) {
        if tex_textures[i]["name"] == uname { return tex_textures[i] }
        i = i + 1
    }
    null
}

func texture_find_index(name) {
    const uname = name.upper()
    if uname == "-" || uname == "" { return -1 }
    let i = 0
    while i < len(tex_textures) {
        if tex_textures[i]["name"] == uname { return i }
        i = i + 1
    }
    -1
}

func texture_get_column(texnum, col) {
    if texnum < 0 || texnum >= len(tex_textures) { return null }
    const tex = tex_textures[texnum]
    const w = tex["width"]
    const h = tex["height"]
    const actual_col = ((col % w) + w) % w
    const cache_key = f"{texnum}_{actual_col}"
    if tex_texture_cache.has(cache_key) { return tex_texture_cache[cache_key] }
    let column = []
    let i = 0
    while i < h { column.push(0); i = i + 1 }
    for pdef in tex["patches"] {
        const pname_idx = pdef["patch"]
        if pname_idx >= len(tex_pnames) { continue }
        const pname = tex_pnames[pname_idx]
        const lump_idx = wad_find(pname)
        if lump_idx < 0 { continue }
        const pcol = actual_col - pdef["originx"]
        if pcol < 0 { continue }
        const patch_data = wad_read(lump_idx)
        const patch_width = read_u16(patch_data, 0)
        if pcol >= patch_width { continue }
        const col_ofs = read_i32(patch_data, 8 + pcol * 4)
        let post_ofs = col_ofs
        while post_ofs < len(patch_data) {
            const topdelta = patch_data[post_ofs]
            if topdelta == 255 { break }
            const post_len = patch_data[post_ofs + 1]
            let j = 0
            while j < post_len {
                const dest_y = topdelta + pdef["originy"] + j
                if dest_y >= 0 && dest_y < h {
                    column[dest_y] = patch_data[post_ofs + 3 + j]
                }
                j = j + 1
            }
            post_ofs = post_ofs + post_len + 4
        }
    }
    tex_texture_cache[cache_key] = column
    column
}

func texture_get_flat(name) {
    const uname = name.upper()
    if tex_flat_cache.has(uname) { return tex_flat_cache[uname] }
    if !tex_flats.has(uname) { return null }
    const lump_idx = tex_flats[uname]
    const data = wad_read(lump_idx)
    if len(data) != 4096 { return null }
    tex_flat_cache[uname] = data
    data
}

func texture_get_patch(lump_idx) {
    if lump_idx < 0 { return null }
    const data = wad_read(lump_idx)
    if len(data) < 8 { return null }
    {
        "width": read_u16(data, 0),
        "height": read_u16(data, 2),
        "leftoffset": read_i16(data, 4),
        "topoffset": read_i16(data, 6),
        "data": data
    }
}

func texture_draw_patch_column(patch, col, dest, dest_ofs, dest_h, colormap) {
    if patch == null { return }
    const data = patch["data"]
    const w = patch["width"]
    if col < 0 || col >= w { return }
    const col_ofs = read_i32(data, 8 + col * 4)
    let post_ofs = col_ofs
    while post_ofs < len(data) {
        const topdelta = data[post_ofs]
        if topdelta == 255 { return }
        const length = data[post_ofs + 1]
        let j = 0
        while j < length {
            const y = topdelta + j
            if y >= 0 && y < dest_h {
                let px = data[post_ofs + 3 + j]
                if colormap != null && px < 256 { px = colormap[px] }
                dest[dest_ofs + y] = px
            }
            j = j + 1
        }
        post_ofs = post_ofs + length + 4
    }
}

func palette_rgb(index) {
    if index < 0 || index >= 256 { return {"r": 0, "g": 0, "b": 0} }
    tex_palette[index]
}

func colormap_index(lightlevel, dist) {
    let level = lightlevel >> 4
    if level < 0 { level = 0 }
    if level >= NUMCOLORMAPS { level = NUMCOLORMAPS - 1 }
    const diminish = fixed_to_int(dist) >> 4
    let idx = (NUMCOLORMAPS - 1) - level + diminish
    if idx < 0 { idx = 0 }
    if idx >= NUMCOLORMAPS { idx = NUMCOLORMAPS - 1 }
    idx
}

func get_colormap(idx) {
    if idx < 0 { idx = 0 }
    if idx >= len(tex_colormaps) { idx = len(tex_colormaps) - 1 }
    tex_colormaps[idx]
}
let bsp_validcount = 0

func bsp_new_validcount() {
    bsp_validcount = bsp_validcount + 1
}

func r_render_bsp_node(node_idx, render_subsector_fn) {
    if node_idx >= 32768 {
        render_subsector_fn(node_idx & 32767)
        return
    }
    if node_idx < 0 || node_idx >= map_num_nodes { return }
    const node = map_nodes[node_idx]
    const side = point_on_side(player_x, player_y, node["x"], node["y"], node["dx"], node["dy"])
    r_render_bsp_node(node["children"][side], render_subsector_fn)
    const other = if side == 0 { 1 } else { 0 }
    if r_check_bbox(node["bbox"][other]) {
        r_render_bsp_node(node["children"][other], render_subsector_fn)
    }
}

func r_check_bbox(bbox) {
    const boxx = if player_x <= bbox["left"] { 0 }
                 else if player_x < bbox["right"] { 1 }
                 else { 2 }
    const boxy = if player_y >= bbox["top"] { 0 }
                 else if player_y > bbox["bottom"] { 1 }
                 else { 2 }
    const boxpos = boxy * 3 + boxx
    if boxpos == 4 { return true }
    const checkcoord = [
        [3, 0, 2, 1], [3, 0, 2, 0], [3, 1, 2, 0],
        [3, 0, 3, 1], [-1,-1,-1,-1], [2, 0, 2, 1],
        [3, 0, 3, 0], [2, 0, 3, 1], [2, 0, 3, 0]
    ]
    const cc = checkcoord[boxpos]
    if cc[0] == -1 { return true }
    const x1 = if cc[0] == 2 { bbox["left"] } else { bbox["right"] }
    const y1 = if cc[1] == 0 { bbox["top"] } else { bbox["bottom"] }
    const x2 = if cc[2] == 2 { bbox["left"] } else { bbox["right"] }
    const y2 = if cc[3] == 0 { bbox["top"] } else { bbox["bottom"] }
    const angle1 = r_point_to_angle(player_x, player_y, x1, y1) - player_angle
    const angle2 = r_point_to_angle(player_x, player_y, x2, y2) - player_angle
    const span = angle1 - angle2
    if span >= ANG180 { return true }
    let tspan = angle1 + clipangle
    if tspan > 2 * clipangle {
        tspan = tspan - 2 * clipangle
        if tspan >= span { return false }
    }
    tspan = clipangle - angle2
    if tspan > 2 * clipangle {
        tspan = tspan - 2 * clipangle
        if tspan >= span { return false }
    }
    true
}

let clipangle = ANG90

func bsp_init() {
    clipangle = point_to_angle_2(0, 0, VIEWWIDTH << FRACBITS, (VIEWWIDTH / 2) << FRACBITS)
}
let r_framebuffer = []
let r_occlusion = []
let r_floorclip = []
let r_ceilingclip = []
let r_viewangle = 0
let r_viewx = 0
let r_viewy = 0
let r_viewz = 0
let r_viewsin = 0
let r_viewcos = 0
let r_centerx = 0
let r_centery = 0
let r_projection = 0
let r_vissprites = []
let r_visplanes = []
let r_screenheightarray = []
let r_xtoviewangle = []

func render_init() {
    r_framebuffer = []
    let i = 0
    while i < SCREENWIDTH * SCREENHEIGHT {
        r_framebuffer.push(0)
        i = i + 1
    }
    r_occlusion = []
    r_floorclip = []
    r_ceilingclip = []
    r_screenheightarray = []
    i = 0
    while i < SCREENWIDTH {
        r_occlusion.push(0)
        r_floorclip.push(VIEWHEIGHT)
        r_ceilingclip.push(-1)
        r_screenheightarray.push(0)
        i = i + 1
    }
    r_centerx = VIEWWIDTH / 2
    r_centery = VIEWHEIGHT / 2
    r_projection = r_centerx << FRACBITS
    r_xtoviewangle = []
    i = 0
    while i < VIEWWIDTH + 1 {
        const f = atan((i - r_centerx + 0.5) / (r_centerx * 1.0))
        const pi = 3.14159265358979323846
        const a = floor(-f * (ANG180 * 1.0) / pi + 0.5)
        r_xtoviewangle.push(a)
        i = i + 1
    }
    bsp_init()
}

func render_player_view() {
    r_viewx = player_x
    r_viewy = player_y
    r_viewz = player_viewz
    r_viewangle = player_angle
    r_viewsin = fine_sine(r_viewangle)
    r_viewcos = fine_cosine(r_viewangle)
    r_vissprites = []
    r_visplanes = []
    let i = 0
    while i < SCREENWIDTH {
        r_occlusion[i] = 0
        r_floorclip[i] = VIEWHEIGHT
        r_ceilingclip[i] = -1
        i = i + 1
    }
    render_clear_fb()
    bsp_new_validcount()
    r_render_bsp_node(map_num_nodes - 1, r_render_subsector)
    r_draw_vissprites()
}

func render_clear_fb() {
    let i = 0
    while i < SCREENWIDTH * SCREENHEIGHT {
        r_framebuffer[i] = 0
        i = i + 1
    }
}

func r_render_subsector(ssnum) {
    if ssnum < 0 || ssnum >= map_num_subsectors { return }
    const ss = map_subsectors[ssnum]
    const sector = ss["sector"]
    if sector == null { return }
    let i = 0
    while i < ss["numlines"] {
        const seg_idx = ss["firstline"] + i
        if seg_idx < map_num_segs {
            r_add_line(map_segs[seg_idx])
        }
        i = i + 1
    }
}

func r_add_line(seg) {
    const v1 = seg["v1"]
    const v2 = seg["v2"]
    const angle1 = r_point_to_angle(r_viewx, r_viewy, v1["x"], v1["y"]) - r_viewangle
    const angle2 = r_point_to_angle(r_viewx, r_viewy, v2["x"], v2["y"]) - r_viewangle
    const span = angle1 - angle2
    if span <= 0 { return }
    if span >= ANG180 { return }
    let rw_angle1 = angle1
    let tspan = angle1 + clipangle
    if tspan > 2 * clipangle {
        tspan = tspan - 2 * clipangle
        if tspan >= span { return }
        rw_angle1 = clipangle
    }
    tspan = clipangle - angle2
    if tspan > 2 * clipangle {
        tspan = tspan - 2 * clipangle
        if tspan >= span { return }
    }
    const x1 = r_angle_to_x(rw_angle1 + r_viewangle)
    let x2 = r_angle_to_x(angle2 + r_viewangle)
    if x1 == x2 { return }
    x2 = x2 - 1
    if x1 >= VIEWWIDTH || x2 < 0 { return }
    const clipped_x1 = if x1 < 0 { 0 } else { x1 }
    const clipped_x2 = if x2 >= VIEWWIDTH { VIEWWIDTH - 1 } else { x2 }
    let all_occluded = true
    let chk = clipped_x1
    while chk <= clipped_x2 {
        if r_occlusion[chk] == 0 { all_occluded = false; chk = clipped_x2 + 1 }
        chk = chk + 1
    }
    if all_occluded { return }
    r_draw_seg(seg, clipped_x1, clipped_x2, rw_angle1)
}

func r_angle_to_x(angle) {
    let a = angle - r_viewangle
    while a > ANG180 { a = a - ANG360 }
    while a < -ANG180 { a = a + ANG360 }
    if a > ANG90 { return 0 }
    if a < -ANG90 { return VIEWWIDTH }
    const t = fine_tangent((ANG90 - a) >> ANGLETOFINESHIFT << ANGLETOFINESHIFT)
    const x = r_centerx - fixed_mul(t, r_projection >> FRACBITS)
    if x < 0 { 0 } else if x > VIEWWIDTH { VIEWWIDTH } else { x }
}

func r_draw_seg(seg, x1, x2, rw_angle1) {
    const line = seg["linedef"]
    if line == null { return }
    const frontsector = seg["frontsector"]
    const backsector = seg["backsector"]
    if frontsector == null { return }
    const v1 = seg["v1"]
    const dx = v1["x"] - r_viewx
    const dy = v1["y"] - r_viewy
    const rw_dist = abs(fixed_mul(dx, r_viewsin) - fixed_mul(dy, r_viewcos))
    if rw_dist <= 0 { return }
    const worldfront_floor = frontsector["floorheight"] - r_viewz
    const worldfront_ceiling = frontsector["ceilingheight"] - r_viewz
    const light = frontsector["lightlevel"]
    const cmap_idx = colormap_index(light, rw_dist)
    const cmap = get_colormap(cmap_idx)
    const toptex = if seg["sidedef"] != null { texture_find_index(seg["sidedef"]["toptexture"]) } else { -1 }
    const midtex = if seg["sidedef"] != null { texture_find_index(seg["sidedef"]["midtexture"]) } else { -1 }
    const bottex = if seg["sidedef"] != null { texture_find_index(seg["sidedef"]["bottomtexture"]) } else { -1 }
    let has_back = backsector != null
    let worldback_floor = 0
    let worldback_ceiling = 0
    if has_back {
        worldback_floor = backsector["floorheight"] - r_viewz
        worldback_ceiling = backsector["ceilingheight"] - r_viewz
    }
    let x = x1
    while x <= x2 {
        if r_occlusion[x] != 0 { x = x + 1; continue }
        const angle = r_xtoviewangle[x]
        const rw_angle = r_viewangle + angle
        const dist = fixed_div(r_projection, fine_cosine((rw_angle - r_viewangle) & (ANG360 - 1)))
        if dist <= 0 { x = x + 1; continue }
        const scale = fixed_div(r_projection, dist >> 8)
        const top_y = r_centery - fixed_to_int(fixed_mul(worldfront_ceiling, scale))
        const bot_y = r_centery - fixed_to_int(fixed_mul(worldfront_floor, scale))
        const ceil_clip = r_ceilingclip[x] + 1
        const floor_clip = r_floorclip[x] - 1
        if !has_back {
            const wall_top = if top_y < ceil_clip { ceil_clip } else { top_y }
            const wall_bot = if bot_y > floor_clip { floor_clip } else { bot_y }
            if midtex >= 0 {
                const tex = tex_textures[midtex]
                const tex_col = r_calc_texcol(seg, rw_angle, dist)
                r_draw_wall_column(x, wall_top, wall_bot, midtex, tex_col, scale, worldfront_ceiling, cmap, line["flags"])
            } else {
                r_draw_color_column(x, wall_top, wall_bot, 96, cmap)
            }
            r_draw_floor_ceiling(x, top_y, bot_y, ceil_clip, floor_clip, frontsector, dist, cmap_idx)
            r_occlusion[x] = 1
            r_ceilingclip[x] = VIEWHEIGHT
            r_floorclip[x] = -1
        } else {
            const back_top_y = r_centery - fixed_to_int(fixed_mul(worldback_ceiling, scale))
            const back_bot_y = r_centery - fixed_to_int(fixed_mul(worldback_floor, scale))
            if worldback_ceiling < worldfront_ceiling && toptex >= 0 {
                const wall_top = if top_y < ceil_clip { ceil_clip } else { top_y }
                const wall_bot = if back_top_y > floor_clip { floor_clip } else { back_top_y }
                if wall_top <= wall_bot {
                    const tex_col = r_calc_texcol(seg, rw_angle, dist)
                    r_draw_wall_column(x, wall_top, wall_bot, toptex, tex_col, scale, worldfront_ceiling, cmap, line["flags"])
                }
                if back_top_y > r_ceilingclip[x] { r_ceilingclip[x] = back_top_y }
            }
            if worldback_floor > worldfront_floor && bottex >= 0 {
                const wall_top = if back_bot_y < ceil_clip { ceil_clip } else { back_bot_y }
                const wall_bot = if bot_y > floor_clip { floor_clip } else { bot_y }
                if wall_top <= wall_bot {
                    const tex_col = r_calc_texcol(seg, rw_angle, dist)
                    r_draw_wall_column(x, wall_top, wall_bot, bottex, tex_col, scale, worldback_floor, cmap, line["flags"])
                }
                if back_bot_y < r_floorclip[x] { r_floorclip[x] = back_bot_y }
            }
            r_draw_floor_ceiling(x, top_y, bot_y, ceil_clip, floor_clip, frontsector, dist, cmap_idx)
            if worldback_ceiling == worldfront_ceiling && worldback_floor == worldfront_floor {
                r_occlusion[x] = 0
            }
        }
        x = x + 1
    }
}

func r_calc_texcol(seg, rw_angle, dist) {
    const offset = seg["offset"]
    const sidedef = seg["sidedef"]
    const texoffset = if sidedef != null { sidedef["textureoffset"] } else { 0 }
    const angle = rw_angle - seg["angle"]
    const hyp = fixed_div(dist, fine_cosine(angle >> ANGLETOFINESHIFT << ANGLETOFINESHIFT))
    const sinv = fine_sine(rw_angle >> ANGLETOFINESHIFT << ANGLETOFINESHIFT)
    const rw_offset = fixed_mul(hyp, sinv)
    fixed_to_int(offset + texoffset + rw_offset)
}

func r_draw_wall_column(x, y1, y2, texnum, texcol, scale, world_top, cmap, flags) {
    if y1 > y2 || x < 0 || x >= VIEWWIDTH { return }
    const column = texture_get_column(texnum, texcol)
    if column == null { return }
    const tex_h = len(column)
    if tex_h == 0 { return }
    let y = y1
    while y <= y2 {
        if y >= 0 && y < VIEWHEIGHT {
            const frac_y = ((y - (r_centery - fixed_to_int(fixed_mul(world_top, scale)))) * tex_h) / (y2 - y1 + 1)
            const ty = ((frac_y % tex_h) + tex_h) % tex_h
            let px = column[ty]
            if cmap != null { px = cmap[px] }
            r_framebuffer[y * SCREENWIDTH + x] = px
        }
        y = y + 1
    }
}

func r_draw_color_column(x, y1, y2, color, cmap) {
    if y1 > y2 { return }
    let px = color
    if cmap != null { px = cmap[px] }
    let y = y1
    while y <= y2 {
        if y >= 0 && y < VIEWHEIGHT && x >= 0 && x < SCREENWIDTH {
            r_framebuffer[y * SCREENWIDTH + x] = px
        }
        y = y + 1
    }
}

func r_draw_floor_ceiling(x, top_y, bot_y, ceil_clip, floor_clip, sector, dist, cmap_idx) {
    const ceil_y1 = ceil_clip
    const ceil_y2 = if top_y - 1 < floor_clip { top_y - 1 } else { floor_clip }
    if sector["ceilingpic"] == "F_SKY1" {
        r_draw_sky_column(x, ceil_y1, ceil_y2)
    } else {
        const cflat = texture_get_flat(sector["ceilingpic"])
        if cflat != null && ceil_y1 <= ceil_y2 {
            r_draw_flat_column(x, ceil_y1, ceil_y2, cflat, sector["ceilingheight"], cmap_idx)
        }
    }
    const floor_y1 = if bot_y + 1 > ceil_clip { bot_y + 1 } else { ceil_clip }
    const floor_y2 = floor_clip
    const fflat = texture_get_flat(sector["floorpic"])
    if fflat != null && floor_y1 <= floor_y2 {
        r_draw_flat_column(x, floor_y1, floor_y2, fflat, sector["floorheight"], cmap_idx)
    }
}

func r_draw_flat_column(x, y1, y2, flat, height, cmap_idx) {
    const cmap = get_colormap(cmap_idx)
    let y = y1
    while y <= y2 {
        if y >= 0 && y < VIEWHEIGHT && y != r_centery {
            const dy = abs(y - r_centery)
            const z = abs(height - r_viewz)
            const dist = fixed_div(z, dy << FRACBITS >> 6)
            const s = r_viewsin >> 10
            const c = r_viewcos >> 10
            const mapx = (r_viewx + fixed_mul(dist, c)) >> FRACBITS
            const mapy = (r_viewy - fixed_mul(dist, s)) >> FRACBITS
            const tx = ((mapx & 63) + 64) % 64
            const ty = ((mapy & 63) + 64) % 64
            let px = flat[ty * 64 + tx]
            if cmap != null { px = cmap[px] }
            r_framebuffer[y * SCREENWIDTH + x] = px
        }
        y = y + 1
    }
}

let sky_texture = -1
func r_draw_sky_column(x, y1, y2) {
    if sky_texture < 0 { sky_texture = texture_find_index("SKY1") }
    if sky_texture < 0 { return }
    const tex = tex_textures[sky_texture]
    const angle = r_viewangle + r_xtoviewangle[x]
    const col = fixed_to_int(angle >> ANGLETOFINESHIFT) & (tex["width"] - 1)
    const column = texture_get_column(sky_texture, col)
    if column == null { return }
    let y = y1
    while y <= y2 {
        if y >= 0 && y < VIEWHEIGHT {
            const ty = (y * len(column)) / VIEWHEIGHT
            r_framebuffer[y * SCREENWIDTH + x] = column[((ty % len(column)) + len(column)) % len(column)]
        }
        y = y + 1
    }
}

func r_draw_vissprites() {
    for vs in r_vissprites {
        r_draw_sprite(vs)
    }
}

func r_add_vissprite(thing, tx, tz) {
    if tz <= 4 * FRACUNIT { return }
    const scale = fixed_div(r_projection, tz)
    const x_screen = r_centerx + fixed_to_int(fixed_mul(tx, scale))
    r_vissprites.push({
        "thing": thing,
        "x": x_screen,
        "scale": scale,
        "dist": tz
    })
}

func r_draw_sprite(vs) {
    const thing = vs["thing"]
    if thing == null { return }
    const sprite_name = thing_get_sprite_name(thing)
    if sprite_name == null { return }
    const lump_idx = if tex_sprite_lumps.has(sprite_name) { tex_sprite_lumps[sprite_name] } else { -1 }
    if lump_idx < 0 { return }
    const patch = texture_get_patch(lump_idx)
    if patch == null { return }
    const scale = vs["scale"]
    const x = vs["x"] - fixed_to_int(fixed_mul(patch["leftoffset"] << FRACBITS, scale))
    const dist = vs["dist"]
    const cmap_idx = colormap_index(thing["sector_light"], dist)
    const cmap = get_colormap(cmap_idx)
    let col = 0
    while col < patch["width"] {
        const sx = x + fixed_to_int(col * scale)
        if sx >= 0 && sx < VIEWWIDTH && r_occlusion[sx] == 0 {
            const top = r_centery - fixed_to_int(fixed_mul((patch["topoffset"] << FRACBITS), scale))
            let dest_col = []
            let j = 0
            while j < VIEWHEIGHT { dest_col.push(-1); j = j + 1 }
            texture_draw_patch_column(patch, col, dest_col, 0, VIEWHEIGHT, cmap)
            j = 0
            while j < VIEWHEIGHT {
                const sy = top + fixed_to_int(j * scale)
                if sy >= r_ceilingclip[sx] + 1 && sy <= r_floorclip[sx] - 1 && dest_col[j] >= 0 {
                    if sy >= 0 && sy < VIEWHEIGHT {
                        r_framebuffer[sy * SCREENWIDTH + sx] = dest_col[j]
                    }
                }
                j = j + 1
            }
        }
        col = col + 1
    }
}

func render_blit(window) {
    let y = 0
    while y < SCREENHEIGHT {
        let x = 0
        while x < SCREENWIDTH {
            const px = r_framebuffer[y * SCREENWIDTH + x]
            const rgb = palette_rgb(px)
            sdl_set_color(window, rgb["r"], rgb["g"], rgb["b"])
            sdl_fill_rect(window, x * SCREENSCALE, y * SCREENSCALE, SCREENSCALE, SCREENSCALE)
            x = x + 1
        }
        y = y + 1
    }
}

func thing_get_sprite_name(thing) {
    if thing == null || thing["state"] == null { return null }
    const state = thing["state"]
    if state["sprite"] == null { return null }
    const frame = state["frame"] & 31
    const frame_char = char_at("ABCDEFGHIJKLMNOPQRSTUVWXYZ", frame)
    state["sprite"] + frame_char + "0"
}
let player_x = 0
let player_y = 0
let player_z = 0
let player_angle = 0
let player_viewz = 0
let player_momx = 0
let player_momy = 0
let player_health = 100
let player_armor = 0
let player_armortype = 0
let player_ammo = [50, 0, 0, 0]
let player_maxammo = [200, 50, 300, 50]
let player_weapons = [true, true, false, false, false, false, false, false, false]
let player_readyweapon = wp_pistol
let player_pendingweapon = wp_pistol
let player_keys = [false, false, false, false, false, false]
let player_powers = [0, 0, 0, 0, 0, 0]
let player_cheats = 0
let player_killcount = 0
let player_itemcount = 0
let player_secretcount = 0
let player_damagecount = 0
let player_bonuscount = 0
let player_extralight = 0
let player_attacking = false
let player_using = false
let player_running = false
let player_sector = null
let player_floorz = 0
let player_ceilingz = 0
let player_refire = 0
let player_dead = false
let player_viewheight = VIEWHEIGHT_FRAC
let player_deltaviewheight = 0

func player_spawn(x, y, angle) {
    player_x = x
    player_y = y
    player_z = 0
    player_angle = angle * ANG45 / 45
    player_momx = 0
    player_momy = 0
    player_health = 100
    player_armor = 0
    player_armortype = 0
    player_ammo = [50, 0, 0, 0]
    player_maxammo = [200, 50, 300, 50]
    player_weapons = [true, true, false, false, false, false, false, false, false]
    player_readyweapon = wp_pistol
    player_pendingweapon = wp_pistol
    player_keys = [false, false, false, false, false, false]
    player_powers = [0, 0, 0, 0, 0, 0]
    player_killcount = 0
    player_itemcount = 0
    player_secretcount = 0
    player_damagecount = 0
    player_bonuscount = 0
    player_extralight = 0
    player_dead = false
    player_refire = 0
    player_viewheight = VIEWHEIGHT_FRAC
    player_deltaviewheight = 0
    const ss_idx = map_get_subsector(player_x, player_y)
    if ss_idx < map_num_subsectors {
        player_sector = map_subsectors[ss_idx]["sector"]
        if player_sector != null {
            player_floorz = player_sector["floorheight"]
            player_ceilingz = player_sector["ceilingheight"]
        }
    }
    player_z = player_floorz
    player_viewz = player_z + player_viewheight
}

func player_think(cmd) {
    if player_dead { return }
    player_move(cmd)
    player_calc_height()
    if player_damagecount > 0 { player_damagecount = player_damagecount - 1 }
    if player_bonuscount > 0 { player_bonuscount = player_bonuscount - 1 }
    let i = 0
    while i < NUMPOWERS {
        if player_powers[i] > 0 { player_powers[i] = player_powers[i] - 1 }
        i = i + 1
    }
    if player_using { player_use_lines() }
}

func player_move(cmd) {
    const forwardmove = cmd["forward"]
    const sidemove = cmd["side"]
    const angleturn = cmd["turn"]
    player_running = cmd["run"]
    player_angle = player_angle + angleturn
    while player_angle >= ANG360 { player_angle = player_angle - ANG360 }
    while player_angle < 0 { player_angle = player_angle + ANG360 }
    if forwardmove != 0 {
        const thrust = if player_running { forwardmove * 2 } else { forwardmove }
        player_momx = player_momx + fixed_mul(thrust << 13, fine_cosine(player_angle))
        player_momy = player_momy + fixed_mul(thrust << 13, fine_sine(player_angle))
    }
    if sidemove != 0 {
        const thrust = if player_running { sidemove * 2 } else { sidemove }
        const sideangle = (player_angle - ANG90 + ANG360) % ANG360
        player_momx = player_momx + fixed_mul(thrust << 13, fine_cosine(sideangle))
        player_momy = player_momy + fixed_mul(thrust << 13, fine_sine(sideangle))
    }
    const newx = player_x + player_momx
    const newy = player_y + player_momy
    if player_try_move(newx, newy) {
        player_x = newx
        player_y = newy
    } else {
        if player_try_move(newx, player_y) {
            player_x = newx
            player_momy = 0
        } else if player_try_move(player_x, newy) {
            player_y = newy
            player_momx = 0
        } else {
            player_momx = 0
            player_momy = 0
        }
    }
    player_momx = fixed_mul(player_momx, FRICTION)
    player_momy = fixed_mul(player_momy, FRICTION)
    if abs(player_momx) < STOPSPEED { player_momx = 0 }
    if abs(player_momy) < STOPSPEED { player_momy = 0 }
    const ss_idx = map_get_subsector(player_x, player_y)
    if ss_idx < map_num_subsectors {
        player_sector = map_subsectors[ss_idx]["sector"]
        if player_sector != null {
            player_floorz = player_sector["floorheight"]
            player_ceilingz = player_sector["ceilingheight"]
        }
    }
    if player_z < player_floorz {
        player_z = player_floorz
    }
}

func player_try_move(newx, newy) {
    const radius = 16 << FRACBITS
    let i = 0
    while i < map_num_linedefs {
        const line = map_linedefs[i]
        const lx1 = line["v1"]["x"]
        const ly1 = line["v1"]["y"]
        const lx2 = line["v2"]["x"]
        const ly2 = line["v2"]["y"]
        if newx + radius < line["bbox"]["left"] || newx - radius > line["bbox"]["right"] ||
           newy + radius < line["bbox"]["bottom"] || newy - radius > line["bbox"]["top"] {
            i = i + 1; continue
        }
        const side1 = point_on_side(player_x, player_y, lx1, ly1, line["dx"], line["dy"])
        const side2 = point_on_side(newx, newy, lx1, ly1, line["dx"], line["dy"])
        if side1 == side2 { i = i + 1; continue }
        if (line["flags"] & ML_BLOCKING) != 0 { return false }
        if line["backsector"] == null { return false }
        const front = line["frontsector"]
        const back = line["backsector"]
        if front == null || back == null { return false }
        const floor_h = if back["floorheight"] > front["floorheight"] { back["floorheight"] } else { front["floorheight"] }
        const ceil_h = if back["ceilingheight"] < front["ceilingheight"] { back["ceilingheight"] } else { front["ceilingheight"] }
        if ceil_h - floor_h < (56 << FRACBITS) { return false }
        if floor_h - player_z > MAXSTEP { return false }
        i = i + 1
    }
    true
}

func player_calc_height() {
    player_viewheight = player_viewheight + player_deltaviewheight
    if player_viewheight > VIEWHEIGHT_FRAC {
        player_viewheight = VIEWHEIGHT_FRAC
        player_deltaviewheight = 0
    }
    if player_viewheight < VIEWHEIGHT_FRAC / 2 {
        player_viewheight = VIEWHEIGHT_FRAC / 2
        if player_deltaviewheight <= 0 { player_deltaviewheight = 1 }
    }
    player_viewz = player_z + player_viewheight
    if player_viewz > player_ceilingz - 4 * FRACUNIT {
        player_viewz = player_ceilingz - 4 * FRACUNIT
    }
}

func player_use_lines() {
    const useangle = player_angle
    const x2 = player_x + fixed_mul(USERANGE, fine_cosine(useangle))
    const y2 = player_y + fixed_mul(USERANGE, fine_sine(useangle))
    let i = 0
    while i < map_num_linedefs {
        const line = map_linedefs[i]
        if line["special"] == 0 { i = i + 1; continue }
        const side1 = point_on_side(player_x, player_y, line["v1"]["x"], line["v1"]["y"], line["dx"], line["dy"])
        const side2 = point_on_side(x2, y2, line["v1"]["x"], line["v1"]["y"], line["dx"], line["dy"])
        if side1 != side2 {
            doors_use_line(line, side1)
        }
        i = i + 1
    }
    player_using = false
}

func player_damage(damage, source) {
    if player_dead { return }
    if player_powers[pw_invulnerability] > 0 { return }
    if player_armortype > 0 {
        let saved = damage / 3
        if player_armortype == 1 { saved = damage / 3 }
        if saved > player_armor { saved = player_armor }
        player_armor = player_armor - saved
        damage = damage - saved
        if player_armor <= 0 { player_armortype = 0 }
    }
    player_health = player_health - damage
    player_damagecount = player_damagecount + damage
    if player_damagecount > 100 { player_damagecount = 100 }
    if player_health <= 0 {
        player_health = 0
        player_dead = true
    }
}

func player_give_weapon(weapon) {
    if weapon < 0 || weapon >= NUMWEAPONS { return false }
    if player_weapons[weapon] { return false }
    player_weapons[weapon] = true
    player_pendingweapon = weapon
    true
}

func player_give_ammo(ammotype, count) {
    if ammotype < 0 || ammotype >= NUMAMMO { return false }
    if player_ammo[ammotype] >= player_maxammo[ammotype] { return false }
    player_ammo[ammotype] = player_ammo[ammotype] + count
    if player_ammo[ammotype] > player_maxammo[ammotype] {
        player_ammo[ammotype] = player_maxammo[ammotype]
    }
    true
}

func player_give_key(key) {
    if key < 0 || key >= NUMCARDS { return }
    player_keys[key] = true
    player_bonuscount = 6
}

func player_give_health(amount) {
    if player_health >= MAXHEALTH { return false }
    player_health = player_health + amount
    if player_health > MAXHEALTH { player_health = MAXHEALTH }
    true
}

func player_give_armor(armortype, amount) {
    if player_armor >= amount { return false }
    player_armortype = armortype
    player_armor = amount
    true
}
let mobj_list = []
let mobj_id_counter = 0

func mobj_spawn(x, y, mtype) {
    const info = mobjinfo_get(mtype)
    if info == null { return null }
    mobj_id_counter = mobj_id_counter + 1
    const mobj = {
        "id": mobj_id_counter,
        "x": x, "y": y, "z": 0,
        "angle": 0,
        "momx": 0, "momy": 0, "momz": 0,
        "type": mtype,
        "info": info,
        "health": info["spawnhealth"],
        "flags": info["flags"],
        "radius": info["radius"],
        "height": info["height"],
        "speed": info["speed"],
        "state": null,
        "tics": 0,
        "sprite": null,
        "frame": 0,
        "target": null,
        "threshold": 0,
        "reactiontime": info["reactiontime"],
        "movecount": 0,
        "movedir": 8,
        "sector": null,
        "sector_light": 160,
        "floorz": 0,
        "ceilingz": 0,
        "subsector": 0
    }
    mobj_set_state(mobj, info["spawnstate"])
    const ss_idx = map_get_subsector(x, y)
    if ss_idx < map_num_subsectors {
        const sec = map_subsectors[ss_idx]["sector"]
        if sec != null {
            mobj["sector"] = sec
            mobj["sector_light"] = sec["lightlevel"]
            mobj["floorz"] = sec["floorheight"]
            mobj["ceilingz"] = sec["ceilingheight"]
        }
    }
    if (info["flags"] & MF_SPAWNCEILING) != 0 {
        mobj["z"] = mobj["ceilingz"] - info["height"]
    } else {
        mobj["z"] = mobj["floorz"]
    }
    mobj_list.push(mobj)
    mobj
}

func mobj_set_state(mobj, state_idx) {
    if state_idx < 0 || state_idx >= len(game_states) {
        mobj["state"] = null
        mobj["tics"] = -1
        return
    }
    const st = game_states[state_idx]
    mobj["state"] = st
    mobj["tics"] = st["tics"]
    mobj["sprite"] = st["sprite"]
    mobj["frame"] = st["frame"]
}

func mobj_think(mobj) {
    if mobj["tics"] == -1 { return }
    mobj["tics"] = mobj["tics"] - 1
    if mobj["tics"] <= 0 {
        const st = mobj["state"]
        if st != null && st["nextstate"] >= 0 {
            mobj_set_state(mobj, st["nextstate"])
            const new_st = mobj["state"]
            if new_st != null && new_st["action"] != null {
                new_st["action"](mobj)
            }
        } else {
            mobj_remove(mobj)
        }
    }
    if (mobj["flags"] & MF_MISSILE) != 0 {
        mobj["x"] = mobj["x"] + mobj["momx"]
        mobj["y"] = mobj["y"] + mobj["momy"]
        mobj["z"] = mobj["z"] + mobj["momz"]
    } else if mobj["momx"] != 0 || mobj["momy"] != 0 {
        mobj_xy_movement(mobj)
    }
    if (mobj["flags"] & MF_NOGRAVITY) == 0 {
        if mobj["z"] > mobj["floorz"] {
            mobj["momz"] = mobj["momz"] - GRAVITY
        }
        mobj["z"] = mobj["z"] + mobj["momz"]
        if mobj["z"] <= mobj["floorz"] {
            mobj["z"] = mobj["floorz"]
            mobj["momz"] = 0
        }
    }
    const ss_idx = map_get_subsector(mobj["x"], mobj["y"])
    if ss_idx < map_num_subsectors {
        const sec = map_subsectors[ss_idx]["sector"]
        if sec != null {
            mobj["sector"] = sec
            mobj["sector_light"] = sec["lightlevel"]
            mobj["floorz"] = sec["floorheight"]
            mobj["ceilingz"] = sec["ceilingheight"]
        }
    }
}

func mobj_xy_movement(mobj) {
    const newx = mobj["x"] + mobj["momx"]
    const newy = mobj["y"] + mobj["momy"]
    mobj["x"] = newx
    mobj["y"] = newy
    mobj["momx"] = fixed_mul(mobj["momx"], FRICTION)
    mobj["momy"] = fixed_mul(mobj["momy"], FRICTION)
    if abs(mobj["momx"]) < STOPSPEED { mobj["momx"] = 0 }
    if abs(mobj["momy"]) < STOPSPEED { mobj["momy"] = 0 }
}

func mobj_remove(mobj) {
    mobj["flags"] = 0
    mobj["health"] = 0
    mobj["tics"] = -1
    mobj["state"] = null
}

func mobj_damage(target, inflictor, source, damage) {
    if (target["flags"] & MF_SHOOTABLE) == 0 { return }
    if target["health"] <= 0 { return }
    target["health"] = target["health"] - damage
    if target["health"] <= 0 {
        mobj_kill(target, source)
        return
    }
    target["reactiontime"] = 0
    if target["target"] == null || target["target"]["health"] <= 0 {
        target["target"] = source
    }
    if target["info"] != null && target["info"]["painstate"] >= 0 {
        const chance = target["info"]["painchance"]
        if random_int(256) < chance {
            mobj_set_state(target, target["info"]["painstate"])
        }
    }
}

func mobj_kill(target, source) {
    target["flags"] = target["flags"] & ((MF_SHOOTABLE | MF_FLOAT | MF_SKULLFLY) ^ -1)
    target["flags"] = target["flags"] | MF_CORPSE
    target["height"] = target["height"] >> 2
    if (target["flags"] & MF_COUNTKILL) != 0 {
        player_killcount = player_killcount + 1
    }
    if target["info"] != null && target["info"]["deathstate"] >= 0 {
        mobj_set_state(target, target["info"]["deathstate"])
    }
}

func things_spawn_map() {
    mobj_list = []
    mobj_id_counter = 0
    let player_thing = null
    for thing in map_things {
        const ttype = thing["type"]
        const opts = thing["options"]
        if (opts & MTF_NORMAL) == 0 && ttype != 1 && ttype != 11 { continue }
        if ttype == 1 {
            player_thing = thing
            continue
        }
        const mobj = mobj_spawn(thing["x"], thing["y"], ttype)
        if mobj != null {
            mobj["angle"] = thing["angle"] * ANG45 / 45
            if (opts & MTF_AMBUSH) != 0 {
                mobj["flags"] = mobj["flags"] | MF_AMBUSH
            }
        }
    }
    if player_thing != null {
        player_spawn(player_thing["x"], player_thing["y"], player_thing["angle"])
    } else {
        player_spawn(0, 0, 0)
    }
    println(f"Spawned {len(mobj_list)} things, player at ({fixed_to_int(player_x)}, {fixed_to_int(player_y)})")
}

func things_run_thinkers() {
    let i = 0
    while i < len(mobj_list) {
        const mobj = mobj_list[i]
        if mobj["health"] > 0 || (mobj["flags"] & MF_CORPSE) != 0 {
            mobj_think(mobj)
        }
        i = i + 1
    }
}

func things_add_vissprites() {
    for mobj in mobj_list {
        if mobj["state"] == null { continue }
        if mobj["health"] <= 0 && (mobj["flags"] & MF_CORPSE) == 0 { continue }
        const dx = mobj["x"] - r_viewx
        const dy = mobj["y"] - r_viewy
        const tz = fixed_mul(dx, r_viewcos) + fixed_mul(dy, r_viewsin)
        if tz <= 4 * FRACUNIT { continue }
        const tx = fixed_mul(dx, r_viewsin) - fixed_mul(dy, r_viewcos)
        r_add_vissprite(mobj, tx, tz)
    }
}

