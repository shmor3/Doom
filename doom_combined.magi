// Floor lower to lowest surrounding floor, change texture and type
func ev_do_floor_lower_to_lowest_change(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    for sec in sectors {
        if sector_has_active_thinker(sec, "floor") { continue }
        const target = find_lowest_floor_around(sec)
        // Find the floor texture from the model sector (lowest floor neighbor)
        let model_pic = sec["floorpic"]
        let model_special = 0
        for ld in map_linedefs {
            let other = null
            if ld["frontsector"] == sec && ld["backsector"] != null { other = ld["backsector"] }
            if ld["backsector"] == sec && ld["frontsector"] != null { other = ld["frontsector"] }
            if other != null && other["floorheight"] == target {
                model_pic = other["floorpic"]
                model_special = other["special"]
            }
        }
        door_thinkers.push({
            "type": "floor",
            "sector": sec,
            "speed": FLOORSPEED,
            "target": target,
            "direction": -1,
            "crush": false,
            "new_floorpic": model_pic,
            "change_texture": true,
            "change_special": model_special
        })
    }
}

