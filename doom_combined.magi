func check_sight(mobj) {
    if player_dead { return false }
    const sector_m = mobj["sector"]
    if sector_m != null && player_sector != null {
        if map_check_reject(sector_m["index"], player_sector["index"]) { return false }
    }
    const dist = point_to_dist(mobj["x"], mobj["y"], player_x, player_y)
    if dist > 2048 * FRACUNIT { return false }
    true
}

func mobj_try_walk(mobj) {
    if mobj["movedir"] == DI_NODIR { return false }
    const speed = mobj["speed"]
    const dir = mobj["movedir"]
    if dir >= 8 { return false }
    const newx = mobj["x"] + fixed_mul(speed, xspeed[dir])
    const newy = mobj["y"] + fixed_mul(speed, yspeed[dir])
    true
}

func mobj_new_chase_dir(mobj) {
    const dx = player_x - mobj["x"]
    const dy = player_y - mobj["y"]
    let d1 = DI_NODIR
    let d2 = DI_NODIR
    if dx > 10 * FRACUNIT { d1 = DI_EAST }
    else if dx < -10 * FRACUNIT { d1 = DI_WEST }
    if dy > 10 * FRACUNIT { d2 = DI_NORTH }
    else if dy < -10 * FRACUNIT { d2 = DI_SOUTH }
    if d1 != DI_NODIR && d2 != DI_NODIR {
        const diags = [[DI_NODIR]*3, [DI_NODIR]*3, [DI_NODIR]*3]
        if d1 == DI_EAST && d2 == DI_NORTH { mobj["movedir"] = DI_NORTHEAST }
        else if d1 == DI_EAST && d2 == DI_SOUTH { mobj["movedir"] = DI_SOUTHEAST }
        else if d1 == DI_WEST && d2 == DI_NORTH { mobj["movedir"] = DI_NORTHWEST }
        else if d1 == DI_WEST && d2 == DI_SOUTH { mobj["movedir"] = DI_SOUTHWEST }
        else { mobj["movedir"] = d1 }
    } else if d1 != DI_NODIR {
        mobj["movedir"] = d1
    } else if d2 != DI_NODIR {
        mobj["movedir"] = d2
    } else {
        mobj["movedir"] = random_int(8)
    }
    mobj["movecount"] = random_int(15) + 5
}

func p_line_attack(source, angle, range, slope, damage) {
    const cos_a = fine_cosine(angle)
    const sin_a = fine_sine(angle)
    const dx = fixed_mul(range, cos_a)
    const dy = fixed_mul(range, sin_a)
    const dist = point_to_dist(source["x"], source["y"], player_x, player_y)
    if dist < range {
        const ang_to_player = point_to_angle_2(source["x"], source["y"], player_x, player_y)
        let diff = ang_to_player - angle
        while diff > ANG180 { diff = diff - ANG360 }
        while diff < -ANG180 { diff = diff + ANG360 }
        if abs(diff) < ANG45 / 2 {
            player_damage(damage, source)
        }
    }
}

func p_spawn_missile(source, missile_type) {
    const angle = source["angle"]
    const speed = 20 * FRACUNIT
    const mx = fixed_mul(speed, fine_cosine(angle))
    const my = fixed_mul(speed, fine_sine(angle))
    const missile = mobj_spawn(source["x"], source["y"] + 32 * FRACUNIT, 0)
    if missile != null {
        missile["momx"] = mx
        missile["momy"] = my
        missile["angle"] = angle
        missile["flags"] = MF_MISSILE | MF_NOBLOCKMAP | MF_NOGRAVITY
    }
}
let weapon_state = "ready"
let weapon_tics = 0
let weapon_frame = 0
let weapon_flash = false
let weapon_flash_tics = 0

const weapon_info = [
    {"ammo": am_noammo, "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_clip,   "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_shell,  "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_clip,   "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_misl,   "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_cell,   "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_cell,   "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_noammo, "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1},
    {"ammo": am_shell,  "upstate": 0, "downstate": 0, "readystate": 0, "atkstate": 0, "flashstate": -1}
]

const ammo_per_shot = [0, 1, 1, 1, 1, 1, 40, 0, 2]

func weapon_tick() {
    if player_dead { return }
    if player_pendingweapon != player_readyweapon {
        weapon_state = "lowering"
        weapon_tics = 6
        return
    }
    match weapon_state {
        "ready" => {
            if player_attacking {
                weapon_fire()
            }
        },
        "firing" => {
            weapon_tics = weapon_tics - 1
            if weapon_tics <= 0 {
                weapon_state = "ready"
                player_refire = 0
            }
        },
        "raising" => {
            weapon_tics = weapon_tics - 1
            if weapon_tics <= 0 {
                weapon_state = "ready"
            }
        },
        "lowering" => {
            weapon_tics = weapon_tics - 1
            if weapon_tics <= 0 {
                player_readyweapon = player_pendingweapon
                weapon_state = "raising"
                weapon_tics = 6
            }
        },
        _ => {}
    }
    if weapon_flash_tics > 0 {
        weapon_flash_tics = weapon_flash_tics - 1
        if weapon_flash_tics <= 0 { weapon_flash = false }
    }
}

func weapon_fire() {
    const wp = player_readyweapon
    const ammo_type = weapon_info[wp]["ammo"]
    const cost = ammo_per_shot[wp]
    if ammo_type != am_noammo {
        if player_ammo[ammo_type] < cost { return }
        player_ammo[ammo_type] = player_ammo[ammo_type] - cost
    }
    weapon_state = "firing"
    weapon_flash = true
    weapon_flash_tics = 4
    player_extralight = 2
    match wp {
        wp_fist => weapon_fire_fist(),
        wp_chainsaw => weapon_fire_chainsaw(),
        wp_pistol => { weapon_fire_bullet(1, 5, 15); weapon_tics = 10 },
        wp_shotgun => { weapon_fire_shotgun(); weapon_tics = 20 },
        wp_chaingun => { weapon_fire_bullet(1, 5, 15); weapon_tics = 4 },
        wp_missile => { weapon_fire_rocket(); weapon_tics = 12 },
        wp_plasma => { weapon_fire_plasma(); weapon_tics = 3 },
        wp_bfg => { weapon_fire_bfg(); weapon_tics = 40 },
        wp_supershotgun => { weapon_fire_ssg(); weapon_tics = 30 },
        _ => { weapon_tics = 10 }
    }
}

func weapon_fire_fist() {
    const angle = player_angle + ((random_int(256) - 128) << 18)
    const damage = (random_int(10) + 1) * 2
    const berserk_mult = if player_powers[pw_strength] > 0 { 10 } else { 1 }
    weapon_melee_attack(damage * berserk_mult, MELEERANGE)
    weapon_tics = 8
}

