}

func weapon_fire_bullet(count, min_dmg, max_dmg) {
    let i = 0
    while i < count {
        const angle = player_angle + ((random_int(256) - 128) << 18)
        const damage = random_int(max_dmg - min_dmg + 1) + min_dmg
        weapon_hitscan(angle, MISSILERANGE, damage)
        i = i + 1
    }
}

