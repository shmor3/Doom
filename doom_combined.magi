// Stop crusher by tag
func ev_do_crusher_stop(line) {
    let i = len(door_thinkers) - 1
    while i >= 0 {
        const t = door_thinkers[i]
        if t["type"] == "crusher" && t["tag"] == line["tag"] {
            // Restore ceiling to top position and remove
            t["sector"]["ceilingheight"] = t["topheight"]
            door_thinkers.splice(i, 1)
        }
        i = i - 1
    }
}

// ===========================================================================
// STAIR BUILDERS (p_floor.c)
// ===========================================================================

// Build stairs: each adjacent sector with same floor texture raises by 8
func ev_build_stairs_8(line) {
    build_stairs(line, STAIRSPEED, STAIRHEIGHT_8)
}

// Build stairs turbo: faster speed, 16 unit steps
func ev_build_stairs_turbo(line) {
    build_stairs(line, TURBOSPEED, STAIRHEIGHT_16)
}

func build_stairs(line, speed, step_height) {
    let sec_idx = -1
    let i = 0
    while i < len(map_sectors) {
        if map_sectors[i]["tag"] == line["tag"] {
            sec_idx = i
            i = len(map_sectors)
        }
        i = i + 1
    }
    if sec_idx < 0 { return }

    let height = map_sectors[sec_idx]["floorheight"] + step_height
    let floor_pic = map_sectors[sec_idx]["floorpic"]

    // First sector in the staircase
    door_thinkers.push({
        "type": "floor",
        "sector": map_sectors[sec_idx],
        "speed": speed,
        "target": height,
        "direction": 1,
        "crush": false,
        "change_texture": false
    })

    // Walk through adjacent sectors building stair steps
    let ok = true
    while ok {
        ok = false
        let found_next = false
        // Find a linedef that borders the current sector
        for ld in map_linedefs {
            let other = null
            if ld["frontsector"] == map_sectors[sec_idx] && ld["backsector"] != null {
                other = ld["backsector"]
            }
            if other == null { continue }

            // The next stair step must have the same floor texture
            if other["floorpic"] != floor_pic { continue }

            // Don't re-add sectors that already have a thinker
            if sector_has_active_thinker(other, "floor") { continue }

            // Find the index of this sector
            let other_idx = -1
            let j = 0
            while j < len(map_sectors) {
                if map_sectors[j] == other { other_idx = j; j = len(map_sectors) }
                j = j + 1
            }
            if other_idx < 0 { continue }

            height = height + step_height
            sec_idx = other_idx
            door_thinkers.push({
                "type": "floor",
                "sector": other,
                "speed": speed,
                "target": height,
                "direction": 1,
                "crush": false,
                "change_texture": false
            })
            ok = true
            found_next = true
            // Break out of for to continue while loop with new sector
            break
        }
        if !found_next { ok = false }
    }
}

