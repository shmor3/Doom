func weapon_melee_attack(damage, range) {
    let closest = null
    let closest_dist = range
    for mobj in mobj_list {
        if (mobj["flags"] & MF_SHOOTABLE) == 0 { continue }
        if mobj["health"] <= 0 { continue }
        const dist = point_to_dist(player_x, player_y, mobj["x"], mobj["y"])
        if dist < closest_dist {
            const ang = point_to_angle_2(player_x, player_y, mobj["x"], mobj["y"])
            let diff = ang - player_angle
            while diff > ANG180 { diff = diff - ANG360 }
            while diff < -ANG180 { diff = diff + ANG360 }
            if abs(diff) < ANG90 {
                closest = mobj
                closest_dist = dist
            }
        }
    }
    if closest != null {
        mobj_damage(closest, null, null, damage)
    }
}

func weapon_hitscan(angle, range, damage) {
    let closest = null
    let closest_dist = range
    for mobj in mobj_list {
        if (mobj["flags"] & MF_SHOOTABLE) == 0 { continue }
        if mobj["health"] <= 0 { continue }
        const dist = point_to_dist(player_x, player_y, mobj["x"], mobj["y"])
        if dist >= range { continue }
        const ang = point_to_angle_2(player_x, player_y, mobj["x"], mobj["y"])
        let diff = ang - angle
        while diff > ANG180 { diff = diff - ANG360 }
        while diff < -ANG180 { diff = diff + ANG360 }
        const half_angle = point_to_angle_2(0, 0, dist, mobj["radius"])
        if abs(diff) < half_angle && dist < closest_dist {
            closest = mobj
            closest_dist = dist
        }
    }
    if closest != null {
        mobj_damage(closest, null, null, damage)
    }
}
let door_thinkers = []

const VDOORSPEED = 2 * FRACUNIT
const VDOORWAIT = 150

func doors_init() {
    door_thinkers = []
}

func doors_use_line(line, side) {
    const special = line["special"]
    if special == 0 { return }
    match special {
        1 => door_open_standard(line),
        26 => door_open_keyed(line, it_bluecard, it_blueskull),
        27 => door_open_keyed(line, it_yellowcard, it_yellowskull),
        28 => door_open_keyed(line, it_redcard, it_redskull),
        31 => door_open_stay(line),
        32 => door_open_keyed_stay(line, it_bluecard, it_blueskull),
        33 => door_open_keyed_stay(line, it_redcard, it_redskull),
        34 => door_open_keyed_stay(line, it_yellowcard, it_yellowskull),
        46 => door_open_stay(line),
        62 => plat_down_wait_up(line),
        63 => door_open_standard(line),
        103 => door_open_standard(line),
        29 => door_open_standard(line),
        111 => door_open_blazing(line),
        117 => door_open_blazing_stay(line),
        _ => door_generic_special(line, special)
    }
}

func doors_walk_line(line) {
    const special = line["special"]
    if special == 0 { return }
    match special {
        2 => door_open_stay(line),
        3 => door_close(line),
        4 => door_open_standard(line),
        16 => door_close_wait_open(line),
        10 => plat_down_wait_up(line),
        22 => plat_down_wait_up(line),
        36 => floor_lower_to_highest(line),
        38 => floor_lower_to_lowest(line),
        52 => { line["special"] = 0 },
        88 => plat_down_wait_up(line),
        90 => door_open_standard(line),
        97 => teleport_thing(line),
        39 => teleport_thing(line),
        _ => {}
    }
}

func door_open_standard(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null && line["backsector"] != null {
        door_open_sector(line["backsector"], VDOORSPEED, VDOORWAIT)
        return
    }
    if sector != null {
        door_open_sector(sector, VDOORSPEED, VDOORWAIT)
    }
}

func door_open_stay(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null && line["backsector"] != null {
        door_open_sector(line["backsector"], VDOORSPEED, -1)
        return
    }
    if sector != null {
        door_open_sector(sector, VDOORSPEED, -1)
    }
}

func door_open_blazing(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null && line["backsector"] != null {
        door_open_sector(line["backsector"], VDOORSPEED * 4, VDOORWAIT)
        return
    }
    if sector != null {
        door_open_sector(sector, VDOORSPEED * 4, VDOORWAIT)
    }
}

func door_open_blazing_stay(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null && line["backsector"] != null {
        door_open_sector(line["backsector"], VDOORSPEED * 4, -1)
        return
    }
    if sector != null {
        door_open_sector(sector, VDOORSPEED * 4, -1)
    }
}

func door_open_keyed(line, card1, card2) {
    if !player_keys[card1] && !player_keys[card2] {
        println("You need a key to open this door.")
        return
    }
    door_open_standard(line)
}

func door_open_keyed_stay(line, card1, card2) {
    if !player_keys[card1] && !player_keys[card2] {
        println("You need a key to open this door.")
        return
    }
    door_open_stay(line)
}

func door_close(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector != null {
        door_close_sector(sector, VDOORSPEED)
    }
}

func door_close_wait_open(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector != null {
        door_thinkers.push({
            "type": "door",
            "sector": sector,
            "direction": -1,
            "speed": VDOORSPEED,
            "topheight": sector["ceilingheight"],
            "topcountdown": VDOORWAIT,
            "phase": "closing"
        })
    }
}

func door_open_sector(sector, speed, wait_tics) {
    let existing = null
    for t in door_thinkers {
        if t["sector"] == sector && t["type"] == "door" { existing = t }
    }
    if existing != null {
        if existing["direction"] == -1 { existing["direction"] = 1; existing["phase"] = "opening" }
        return
    }
    const top = find_lowest_ceiling_around(sector) - 4 * FRACUNIT
    door_thinkers.push({
        "type": "door",
        "sector": sector,
        "direction": 1,
        "speed": speed,
        "topheight": top,
        "topcountdown": wait_tics,
        "phase": "opening"
    })
}

func door_close_sector(sector, speed) {
    const floor = sector["floorheight"]
    door_thinkers.push({
        "type": "door",
        "sector": sector,
        "direction": -1,
        "speed": speed,
        "topheight": sector["ceilingheight"],
        "topcountdown": 0,
        "phase": "closing",
        "bottomheight": floor
    })
}

func plat_down_wait_up(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null { return }
    const low = find_lowest_floor_around(sector)
    door_thinkers.push({
        "type": "plat",
        "sector": sector,
        "speed": VDOORSPEED * 2,
        "low": low,
        "high": sector["floorheight"],
        "wait": 105,
        "count": 0,
        "phase": "down"
    })
}

func floor_lower_to_highest(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null { return }
    const target = find_highest_floor_around(sector)
    door_thinkers.push({
        "type": "floor",
        "sector": sector,
        "speed": FRACUNIT,
        "target": target,
        "direction": if target > sector["floorheight"] { 1 } else { -1 }
    })
}

func floor_lower_to_lowest(line) {
    const sector = find_tagged_sector(line["tag"])
    if sector == null { return }
    const target = find_lowest_floor_around(sector)
    door_thinkers.push({
        "type": "floor",
        "sector": sector,
        "speed": FRACUNIT,
        "target": target,
        "direction": -1
    })
}

func teleport_thing(line) {
    for thing in map_things {
        if thing["type"] == 14 {
            const dest_sector = find_tagged_sector(line["tag"])
            if dest_sector != null {
                player_x = thing["x"]
                player_y = thing["y"]
                player_z = player_floorz
                player_momx = 0
                player_momy = 0
                player_angle = thing["angle"] * ANG45 / 45
            }
            return
        }
    }
}

func door_generic_special(line, special) {
    
}

func doors_run_thinkers() {
    let i = 0
    while i < len(door_thinkers) {
        const t = door_thinkers[i]
        match t["type"] {
            "door" => door_think(t, i),
            "plat" => plat_think(t, i),
            "floor" => floor_think(t, i),
            _ => {}
        }
        i = i + 1
    }
}

func door_think(t, idx) {
    const sector = t["sector"]
    if t["phase"] == "opening" {
        sector["ceilingheight"] = sector["ceilingheight"] + t["speed"]
        if sector["ceilingheight"] >= t["topheight"] {
            sector["ceilingheight"] = t["topheight"]
            if t["topcountdown"] > 0 {
                t["phase"] = "waiting"
                t["topcountdown"] = t["topcountdown"]
            } else if t["topcountdown"] == -1 {
                door_thinkers.splice(idx, 1)
            }
        }
    } else if t["phase"] == "waiting" {
        t["topcountdown"] = t["topcountdown"] - 1
        if t["topcountdown"] <= 0 {
            t["phase"] = "closing"
        }
    } else if t["phase"] == "closing" {
        sector["ceilingheight"] = sector["ceilingheight"] - t["speed"]
        if sector["ceilingheight"] <= sector["floorheight"] {
            sector["ceilingheight"] = sector["floorheight"]
            door_thinkers.splice(idx, 1)
        }
    }
}

func plat_think(t, idx) {
    const sector = t["sector"]
    if t["phase"] == "down" {
        sector["floorheight"] = sector["floorheight"] - t["speed"]
        if sector["floorheight"] <= t["low"] {
            sector["floorheight"] = t["low"]
            t["phase"] = "wait"
            t["count"] = t["wait"]
        }
    } else if t["phase"] == "wait" {
        t["count"] = t["count"] - 1
        if t["count"] <= 0 { t["phase"] = "up" }
    } else if t["phase"] == "up" {
        sector["floorheight"] = sector["floorheight"] + t["speed"]
        if sector["floorheight"] >= t["high"] {
            sector["floorheight"] = t["high"]
            door_thinkers.splice(idx, 1)
        }
    }
}

func floor_think(t, idx) {
    const sector = t["sector"]
    sector["floorheight"] = sector["floorheight"] + t["speed"] * t["direction"]
    if (t["direction"] > 0 && sector["floorheight"] >= t["target"]) ||
       (t["direction"] < 0 && sector["floorheight"] <= t["target"]) {
        sector["floorheight"] = t["target"]
        door_thinkers.splice(idx, 1)
    }
}

func find_tagged_sector(tag) {
    if tag == 0 { return null }
    for sector in map_sectors {
        if sector["tag"] == tag { return sector }
    }
    null
}

func find_lowest_ceiling_around(sector) {
    let lowest = 32767 << FRACBITS
    for line in map_linedefs {
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["ceilingheight"] < lowest {
                lowest = line["backsector"]["ceilingheight"]
            }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["ceilingheight"] < lowest {
                lowest = line["frontsector"]["ceilingheight"]
            }
        }
    }
    lowest
}

func find_lowest_floor_around(sector) {
    let lowest = sector["floorheight"]
    for line in map_linedefs {
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["floorheight"] < lowest { lowest = line["backsector"]["floorheight"] }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["floorheight"] < lowest { lowest = line["frontsector"]["floorheight"] }
        }
    }
    lowest
}

func find_highest_floor_around(sector) {
    let highest = -32767 << FRACBITS
    for line in map_linedefs {
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["floorheight"] > highest { highest = line["backsector"]["floorheight"] }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["floorheight"] > highest { highest = line["frontsector"]["floorheight"] }
        }
    }
    highest
}
let snd_channels = []
let snd_sfx_cache = {}
let snd_stream = null
let snd_music_playing = false
const SND_SAMPLERATE = 11025
const SND_MAXCHANNELS = 8

func sound_init() {
    snd_channels = []
    let i = 0
    while i < SND_MAXCHANNELS {
        snd_channels.push({"active": false, "data": null, "pos": 0, "vol": 255, "pan": 128, "priority": 0})
        i = i + 1
    }
    snd_stream = audio_stream_new(SND_SAMPLERATE)
}

func sound_shutdown() {
    if snd_stream != null {
        audio_drain(snd_stream)
        audio_close(snd_stream)
        snd_stream = null
    }
}

func sound_play(name, x, y, priority) {
    const sfx = sound_load(name)
    if sfx == null { return }
    const dist = point_to_dist(player_x, player_y, x, y)
    if dist > 1200 * FRACUNIT { return }
    const vol = 255 - fixed_to_int(dist) * 255 / 1200
    if vol <= 0 { return }
    const angle = point_to_angle_2(player_x, player_y, x, y)
    let diff = angle - player_angle
    while diff > ANG180 { diff = diff - ANG360 }
    while diff < -ANG180 { diff = diff + ANG360 }
    const pan = 128 + fixed_to_int(fixed_mul(diff / (ANG90 / 128), 128 << FRACBITS))
    const clamped_pan = clamp(pan, 0, 255)
    let best_chan = -1
    let best_prio = priority + 1
    let i = 0
    while i < SND_MAXCHANNELS {
        if !snd_channels[i]["active"] { best_chan = i; i = SND_MAXCHANNELS; continue }
        if snd_channels[i]["priority"] < best_prio {
            best_prio = snd_channels[i]["priority"]
            best_chan = i
        }
        i = i + 1
    }
    if best_chan < 0 { return }
    snd_channels[best_chan] = {
        "active": true,
        "data": sfx,
        "pos": 0,
        "vol": vol,
        "pan": clamped_pan,
        "priority": priority
    }
}

func sound_play_global(name) {
    sound_play(name, player_x, player_y, 200)
}

func sound_load(name) {
    const uname = name.upper()
    if snd_sfx_cache.has(uname) { return snd_sfx_cache[uname] }
    const lump_name = "DS" + uname
    const idx = wad_find(lump_name)
    if idx < 0 { return null }
    const data = wad_read(idx)
    if len(data) < 8 { return null }
    const format = read_u16(data, 0)
    const samplerate = read_u16(data, 2)
    const numsamples = read_i32(data, 4)
    if format != 3 { return null }
    let samples = []
    let i = 0
    while i < numsamples && (8 + i) < len(data) {
        samples.push(data[8 + i])
        i = i + 1
    }
    snd_sfx_cache[uname] = samples
    samples
}

func sound_update() {
    if snd_stream == null { return }
    let mix_buf = []
    const chunk_size = SND_SAMPLERATE / TICRATE
    let s = 0
    while s < chunk_size {
        let left = 0
        let right = 0
        let c = 0
        while c < SND_MAXCHANNELS {
            const ch = snd_channels[c]
            if ch["active"] && ch["data"] != null {
                const pos = ch["pos"]
                if pos < len(ch["data"]) {
                    const sample = (ch["data"][pos] - 128) * ch["vol"] / 255
                    const lpan = 255 - ch["pan"]
                    const rpan = ch["pan"]
                    left = left + sample * lpan / 255
                    right = right + sample * rpan / 255
                    ch["pos"] = pos + 1
                } else {
                    ch["active"] = false
                }
            }
            c = c + 1
        }
        left = clamp(left, -128, 127)
        right = clamp(right, -128, 127)
        mix_buf.push(left * 256)
        mix_buf.push(right * 256)
        s = s + 1
    }
    if len(mix_buf) > 0 {
        audio_write_samples(snd_stream, mix_buf)
    }
}

func music_start(name) {
    const lump_name = "D_" + name.upper()
    const idx = wad_find(lump_name)
    if idx < 0 { return }
    snd_music_playing = true
}

func music_stop() {
    snd_music_playing = false
}

const level_music = [
    "E1M1", "E1M2", "E1M3", "E1M4", "E1M5", "E1M6", "E1M7", "E1M8", "E1M9"
]

func music_start_level(episode, mission) {
    if episode == 1 && mission >= 1 && mission <= 9 {
        music_start(level_music[mission - 1])
    }
}
let hud_stbar_patch = null
let hud_face_patches = {}
let hud_num_patches = []
let hud_arms_patches = []
let hud_key_patches = []
let hud_automap = false
let hud_message = ""
let hud_message_tics = 0

func hud_init() {
    hud_load_stbar()
    hud_load_numbers()
}

func hud_load_stbar() {
    const idx = wad_find("STBAR")
    if idx >= 0 { hud_stbar_patch = texture_get_patch(idx) }
}

func hud_load_numbers() {
    hud_num_patches = []
    let i = 0
    while i < 10 {
        const name = f"STTNUM{i}"
        const idx = wad_find(name)
        if idx >= 0 { hud_num_patches.push(texture_get_patch(idx)) }
        else { hud_num_patches.push(null) }
        i = i + 1
    }
    const minus_idx = wad_find("STTMINUS")
    if minus_idx >= 0 { hud_num_patches.push(texture_get_patch(minus_idx)) }
}

func hud_draw() {
    hud_draw_stbar()
    if hud_message_tics > 0 {
        hud_draw_message()
        hud_message_tics = hud_message_tics - 1
    }
}

func hud_draw_stbar() {
    if hud_stbar_patch != null {
        hud_draw_patch_to_fb(0, ST_Y, hud_stbar_patch)
    } else {
        let x = 0
        while x < SCREENWIDTH {
            let y = ST_Y
            while y < SCREENHEIGHT {
                r_framebuffer[y * SCREENWIDTH + x] = 96
                y = y + 1
            }
            x = x + 1
        }
    }
    hud_draw_number(44, ST_Y + 3, player_ammo[weapon_info[player_readyweapon]["ammo"]], 3)
    hud_draw_number(90, ST_Y + 3, player_health, 3)
    hud_draw_percent(90 + 14 * 3, ST_Y + 3)
    hud_draw_number(221, ST_Y + 3, player_armor, 3)
    hud_draw_percent(221 + 14 * 3, ST_Y + 3)
    hud_draw_keys()
    hud_draw_face()
}

func hud_draw_number(x, y, value, digits) {
    if value < 0 { value = 0 }
    let num = value
    let d = digits
    let xp = x + (d - 1) * 14
    while d > 0 {
        const digit = num % 10
        if digit < len(hud_num_patches) && hud_num_patches[digit] != null {
            hud_draw_patch_to_fb(xp, y, hud_num_patches[digit])
        }
        num = num / 10
        xp = xp - 14
        d = d - 1
    }
}

func hud_draw_percent(x, y) {
    const pct_idx = wad_find("STTPRCNT")
    if pct_idx >= 0 {
        const patch = texture_get_patch(pct_idx)
        if patch != null { hud_draw_patch_to_fb(x, y, patch) }
    }
}

func hud_draw_keys() {
    const key_x = 239
    const key_names = ["STKEYS0", "STKEYS1", "STKEYS2", "STKEYS3", "STKEYS4", "STKEYS5"]
    let i = 0
    while i < NUMCARDS {
        if player_keys[i] {
            const kid = wad_find(key_names[i])
            if kid >= 0 {
                const p = texture_get_patch(kid)
                if p != null { hud_draw_patch_to_fb(key_x, ST_Y + 3 + (i % 3) * 10, p) }
            }
        }
        i = i + 1
    }
}

func hud_draw_face() {
    const health = player_health
    let face_name = "STFST01"
    if health > 80 { face_name = "STFST00" }
    else if health > 60 { face_name = "STFST01" }
    else if health > 40 { face_name = "STFST02" }
    else if health > 20 { face_name = "STFST03" }
    else { face_name = "STFST04" }
    if player_damagecount > 0 { face_name = "STFOUCH0" }
    if player_dead { face_name = "STFDEAD0" }
    const fid = wad_find(face_name)
    if fid >= 0 {
        const p = texture_get_patch(fid)
        if p != null { hud_draw_patch_to_fb(143, ST_Y + 1, p) }
    }
}

func hud_draw_patch_to_fb(x, y, patch) {
    if patch == null { return }
    let col = 0
    while col < patch["width"] {
        const sx = x + col
        if sx >= 0 && sx < SCREENWIDTH {
            texture_draw_patch_column(patch, col, r_framebuffer, sx + y * SCREENWIDTH, SCREENHEIGHT - y, null)
        }
        col = col + 1
    }
}

func hud_show_message(msg) {
    hud_message = msg
    hud_message_tics = TICRATE * 4
}

func hud_draw_message() {
    let x = 0
    let i = 0
    while i < len(hud_message) {
        const c = hud_message.char_at(i)
        const code = to_byte(c)
        if code >= 33 && code <= 95 {
            const name = f"STCFN{code}"
            const fid = wad_find(name)
            if fid >= 0 {
                const p = texture_get_patch(fid)
                if p != null {
                    hud_draw_patch_to_fb(x, 0, p)
                    x = x + p["width"]
                } else { x = x + 8 }
            } else { x = x + 8 }
        } else { x = x + 4 }
        i = i + 1
    }
}

func automap_toggle() {
    hud_automap = !hud_automap
}

func automap_draw() {
    if !hud_automap { return }
    let i = 0
    while i < SCREENWIDTH * VIEWHEIGHT {
        r_framebuffer[i] = 0
        i = i + 1
    }
    const scale = FRACUNIT / 4
    const cx = VIEWWIDTH / 2
    const cy = VIEWHEIGHT / 2
    for line in map_linedefs {
        const flags = line["flags"]
        if (flags & ML_DONTDRAW) != 0 { continue }
        const x1 = cx + fixed_to_int(fixed_mul(line["v1"]["x"] - player_x, scale))
        const y1 = cy - fixed_to_int(fixed_mul(line["v1"]["y"] - player_y, scale))
        const x2 = cx + fixed_to_int(fixed_mul(line["v2"]["x"] - player_x, scale))
        const y2 = cy - fixed_to_int(fixed_mul(line["v2"]["y"] - player_y, scale))
        let color = 96
        if line["backsector"] == null { color = 176 }
        else if line["frontsector"]["floorheight"] != line["backsector"]["floorheight"] { color = 64 }
        else if line["frontsector"]["ceilingheight"] != line["backsector"]["ceilingheight"] { color = 231 }
        else { color = 104 }
        if (flags & ML_SECRET) != 0 { color = 176 }
        automap_draw_line(x1, y1, x2, y2, color)
    }
    automap_draw_player_arrow(cx, cy)
}

func automap_draw_line(x1, y1, x2, y2, color) {
    let dx = abs(x2 - x1)
    let dy = abs(y2 - y1)
    let sx = if x1 < x2 { 1 } else { -1 }
    let sy = if y1 < y2 { 1 } else { -1 }
    let err = dx - dy
    let cx = x1
    let cy = y1
    let steps = 0
    const max_steps = dx + dy + 1
    while steps < max_steps {
        if cx >= 0 && cx < SCREENWIDTH && cy >= 0 && cy < VIEWHEIGHT {
            r_framebuffer[cy * SCREENWIDTH + cx] = color
        }
        if cx == x2 && cy == y2 { return }
        const e2 = 2 * err
        if e2 > -dy { err = err - dy; cx = cx + sx }
        if e2 < dx { err = err + dx; cy = cy + sy }
        steps = steps + 1
    }
}

func automap_draw_player_arrow(cx, cy) {
    const l = 8
    const a = player_angle
    const ca = fine_cosine(a)
    const sa = fine_sine(a)
    const fx = fixed_to_int(fixed_mul(l << FRACBITS, ca))
    const fy = -fixed_to_int(fixed_mul(l << FRACBITS, sa))
    automap_draw_line(cx, cy, cx + fx, cy + fy, 112)
    automap_draw_line(cx, cy, cx - fy / 2, cy + fx / 2, 112)
    automap_draw_line(cx, cy, cx + fy / 2, cy - fx / 2, 112)
}

func intermission_draw(ep, mi, kills, items, secrets, time_secs) {
    render_clear_fb()
    const y = 30
    hud_draw_text(50, y, f"E{ep}M{mi} COMPLETE")
    hud_draw_text(50, y + 20, f"KILLS:   {player_killcount}%")
    hud_draw_text(50, y + 30, f"ITEMS:   {player_itemcount}%")
    hud_draw_text(50, y + 40, f"SECRETS: {player_secretcount}%")
    hud_draw_text(50, y + 60, f"TIME: {time_secs / 60}:{(time_secs % 60):02}")
    hud_draw_text(50, y + 80, "PRESS ENTER TO CONTINUE")
}

func hud_draw_text(x, y, text) {
    let xp = x
    let i = 0
    while i < len(text) {
        const c = text.char_at(i)
        const code = to_byte(c)
        if code >= 33 && code <= 95 {
            const name = f"STCFN{code}"
            const fid = wad_find(name)
            if fid >= 0 {
                const p = texture_get_patch(fid)
                if p != null {
                    hud_draw_patch_to_fb(xp, y, p)
                    xp = xp + p["width"]
                } else { xp = xp + 8 }
            } else { xp = xp + 8 }
        } else { xp = xp + 4 }
        i = i + 1
    }
}
let mobjinfo_table = {}

func tables_init() {
