    actor["flags"] = actor["flags"] | MF_SKULLFLY
    sound_play("SKLATK", actor["x"], actor["y"], 80)
    const angle = actor["angle"]
    const speed = 20 * FRACUNIT
    actor["momx"] = fixed_mul(speed, fine_cosine(angle))
    actor["momy"] = fixed_mul(speed, fine_sine(angle))
    const dist = point_to_dist(actor["x"], actor["y"], player_x, player_y)
    const dz = player_viewz - actor["z"]
    let slope = 0
    if dist > 0 { slope = fixed_div(dz, dist >> 8) }
    actor["momz"] = fixed_mul(speed, slope)
}

