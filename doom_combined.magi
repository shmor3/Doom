    if missile != null {
        missile["momx"] = fixed_mul(speed, fine_cosine(angle))
        missile["momy"] = fixed_mul(speed, fine_sine(angle))
        missile["flags"] = MF_MISSILE | MF_NOBLOCKMAP | MF_NOGRAVITY
        missile["health"] = 100
    }
