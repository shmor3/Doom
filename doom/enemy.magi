func a_skull_attack(mobj) {
    a_face_target(mobj)
    mobj["flags"] = mobj["flags"] | MF_SKULLFLY
    const angle = mobj["angle"]
    mobj["momx"] = fixed_mul(20 * FRACUNIT, fine_cosine(angle))
    mobj["momy"] = fixed_mul(20 * FRACUNIT, fine_sine(angle))
    const dist = point_to_dist(mobj["x"], mobj["y"], player_x, player_y)
    const dz = player_viewz - mobj["z"]
    const slope = if dist != 0 { fixed_div(dz, dist) } else { 0 }
    mobj["momz"] = fixed_mul(20 * FRACUNIT, slope)
}

func a_bruis_attack(mobj) {
    a_face_target(mobj)
    const dist = point_to_dist(mobj["x"], mobj["y"], player_x, player_y)
    if dist < MELEERANGE {
