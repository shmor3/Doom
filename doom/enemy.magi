func a_vilechase(actor) {
    for mobj in mobj_list {
        if (mobj["flags"] & MF_CORPSE) == 0 { continue }
        if mobj["info"] == null { continue }
        if mobj["info"]["raisestate"] < 0 { continue }
        const dist = point_to_dist(actor["x"], actor["y"], mobj["x"], mobj["y"])
        if dist > 896 * FRACUNIT { continue }
        actor["target"] = mobj
        a_face_target(actor)
        mobj["health"] = mobj["info"]["spawnhealth"]
        mobj["flags"] = mobj["info"]["flags"]
        mobj["height"] = mobj["info"]["height"]
        mobj_set_state(mobj, mobj["info"]["raisestate"])
        return
    }
    a_chase(actor)
}

func a_vileattack(actor) {
    if actor["target"] == null { return }
    a_face_target(actor)
    if !check_sight(actor) { return }
    sound_play("BAREXP", actor["x"], actor["y"], 100)
    player_damage(20, actor)
    player_momx = player_momx + fixed_mul(1000 * FRACUNIT, fine_cosine(actor["angle"]))
    player_momy = player_momy + fixed_mul(1000 * FRACUNIT, fine_sine(actor["angle"]))
}

