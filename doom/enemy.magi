    let all_dead = true
    for mobj in mobj_list {
        if mobj["type"] == actor["type"] && mobj["health"] > 0 { all_dead = false }
    }
    if all_dead {
        for line in map_linedefs {
            if line["tag"] == 666 { door_open_tagged(666) }
        }
    }
}

func a_bossdeath(actor) {
    if game_episode == 1 && game_mission == 8 {
        let all_dead = true
        for mobj in mobj_list {
            if mobj["type"] == actor["type"] && mobj != actor && mobj["health"] > 0 {
                all_dead = false
            }
        }
        if all_dead {
            for line in map_linedefs {
                if line["tag"] == 666 {
                    floor_lower_to_lowest_tagged(666)
                }
            }
        }
    }
}

