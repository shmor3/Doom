func a_painshootskull(actor, angle) {
    const skull = mobj_spawn(
        actor["x"] + fixed_mul(64 * FRACUNIT, fine_cosine(angle)),
        actor["y"] + fixed_mul(64 * FRACUNIT, fine_sine(angle)),
        3006
    )
    if skull != null {
        skull["target"] = player_mobj_ref()
        a_skullattack(skull)
    }
}

func a_paindie(actor) {
    a_fall(actor)
    a_painshootskull(actor, actor["angle"] + ANG90)
    a_painshootskull(actor, actor["angle"] + ANG180)
    a_painshootskull(actor, actor["angle"] + ANG270)
}

