const DI_EAST = 0
const DI_NORTHEAST = 1
const DI_NORTH = 2
const DI_NORTHWEST = 3
const DI_WEST = 4
const DI_SOUTHWEST = 5
const DI_SOUTH = 6
const DI_SOUTHEAST = 7
const DI_NODIR = 8

const xspeed = [FRACUNIT, 47000, 0, -47000, -FRACUNIT, -47000, 0, 47000]
const yspeed = [0, 47000, FRACUNIT, 47000, 0, -47000, -FRACUNIT, -47000]
const opposite = [DI_WEST, DI_SOUTHWEST, DI_SOUTH, DI_SOUTHEAST, DI_EAST, DI_NORTHEAST, DI_NORTH, DI_NORTHWEST, DI_NODIR]
const diags = [DI_NORTHWEST, DI_NORTHEAST, DI_SOUTHWEST, DI_SOUTHEAST]

func a_look(actor) {
    actor["threshold"] = 0
    if actor["sector"] != null && actor["sector"]["soundtarget"] != null {
        const targ = actor["sector"]["soundtarget"]
        actor["target"] = targ
        if (actor["flags"] & MF_AMBUSH) != 0 {
            if !check_sight(actor) { return }
        }
    } else {
        if !check_sight(actor) { return }
        actor["target"] = player_mobj_ref()
    }
    if actor["info"] != null && actor["info"]["seesound"] != "" {
        sound_play(actor["info"]["seesound"], actor["x"], actor["y"], 100)
    }
    if actor["info"] != null && actor["info"]["seestate"] >= 0 {
        mobj_set_state(actor, actor["info"]["seestate"])
    }
}

func a_chase(actor) {
    if actor["reactiontime"] > 0 { actor["reactiontime"] = actor["reactiontime"] - 1 }
    if actor["threshold"] > 0 {
        if actor["target"] == null || (actor["target"]["health"] != null && actor["target"]["health"] <= 0) {
            actor["threshold"] = 0
        } else {
            actor["threshold"] = actor["threshold"] - 1
        }
    }
    if actor["target"] == null || actor["target"]["health"] <= 0 {
        actor["target"] = player_mobj_ref()
        if actor["target"] == null { return }
    }
    if (actor["flags"] & MF_JUSTHIT) != 0 {
        actor["flags"] = actor["flags"] & ((MF_JUSTHIT) ^ -1)
        actor["movecount"] = 0
        return
    }
    if actor["info"] != null && actor["info"]["meleestate"] >= 0 {
        const dist = point_to_dist(actor["x"], actor["y"], player_x, player_y)
        if dist < MELEERANGE {
            if actor["info"]["attacksound"] != "" {
                sound_play(actor["info"]["attacksound"], actor["x"], actor["y"], 80)
            }
            mobj_set_state(actor, actor["info"]["meleestate"])
            return
        }
    }
    if actor["info"] != null && actor["info"]["missilestate"] >= 0 {
        if actor["movecount"] <= 0 || !check_sight(actor) {
        } else if random_int(256) < 200 {
            mobj_set_state(actor, actor["info"]["missilestate"])
            actor["flags"] = actor["flags"] | MF_JUSTATTACKED
            return
        }
    }
    actor["movecount"] = actor["movecount"] - 1
    if actor["movecount"] < 0 || !p_move(actor) {
        p_new_chase_dir(actor)
    }
    if actor["info"] != null && actor["info"]["activesound"] != "" {
        if random_int(256) < 3 {
            sound_play(actor["info"]["activesound"], actor["x"], actor["y"], 50)
        }
    }
}

func a_face_target(actor) {
    if actor["target"] == null { return }
    actor["flags"] = actor["flags"] & ((MF_AMBUSH) ^ -1)
    actor["angle"] = point_to_angle_2(actor["x"], actor["y"], player_x, player_y)
    if player_powers[pw_invisibility] > 0 {
        actor["angle"] = actor["angle"] + ((random_int(256) - 128) << 21)
    }
}

func a_posattack(actor) {
    if actor["target"] == null { return }
    a_face_target(actor)
    const angle = actor["angle"] + ((random_int(256) - 128) << 20)
    sound_play("PISTOL", actor["x"], actor["y"], 80)
    const damage = ((random_int(256) % 5) + 1) * 3
    p_line_attack(actor, angle, MISSILERANGE, 0, damage)
}

func a_sposattack(actor) {
    if actor["target"] == null { return }
    a_face_target(actor)
    sound_play("SHOTGN", actor["x"], actor["y"], 80)
    let i = 0
    while i < 3 {
        const angle = actor["angle"] + ((random_int(256) - 128) << 20)
        const damage = ((random_int(256) % 5) + 1) * 3
        p_line_attack(actor, angle, MISSILERANGE, 0, damage)
        i = i + 1
    }
}

