const DI_EAST = 0
const DI_NORTHEAST = 1
const DI_NORTH = 2
const DI_NORTHWEST = 3
const DI_WEST = 4
const DI_SOUTHWEST = 5
const DI_SOUTH = 6
const DI_SOUTHEAST = 7
const DI_NODIR = 8
const NUMDIR = 9

const xspeed = [FRACUNIT, 47000, 0, -47000, -FRACUNIT, -47000, 0, 47000]
const yspeed = [0, 47000, FRACUNIT, 47000, 0, -47000, -FRACUNIT, -47000]

func a_look(mobj) {
    if mobj["target"] != null && mobj["target"]["health"] > 0 { return }
    const dist = point_to_dist(mobj["x"], mobj["y"], player_x, player_y)
    if dist < 1024 * FRACUNIT {
        if check_sight(mobj) {
            mobj["target"] = {"type": "player", "x": player_x, "y": player_y, "health": player_health}
            if mobj["info"] != null && mobj["info"]["seestate"] >= 0 {
                mobj_set_state(mobj, mobj["info"]["seestate"])
            }
        }
    }
}

func a_chase(mobj) {
    if mobj["reactiontime"] > 0 { mobj["reactiontime"] = mobj["reactiontime"] - 1 }
    if mobj["target"] == null || mobj["target"]["health"] <= 0 {
        mobj["target"] = {"type": "player", "x": player_x, "y": player_y, "health": player_health}
    }
    if mobj["threshold"] > 0 { mobj["threshold"] = mobj["threshold"] - 1 }
    const target = mobj["target"]
    const dist = point_to_dist(mobj["x"], mobj["y"], player_x, player_y)
    if mobj["info"] != null && mobj["info"]["meleestate"] >= 0 && dist < MELEERANGE {
        a_face_target(mobj)
        mobj_set_state(mobj, mobj["info"]["meleestate"])
        return
    }
    if mobj["info"] != null && mobj["info"]["missilestate"] >= 0 && mobj["movecount"] <= 0 {
        if check_sight(mobj) && random_int(256) < 200 {
            a_face_target(mobj)
            mobj_set_state(mobj, mobj["info"]["missilestate"])
            mobj["movecount"] = random_int(15) + 5
            return
        }
    }
    mobj["movecount"] = mobj["movecount"] - 1
    if mobj["movecount"] < 0 || !mobj_try_walk(mobj) {
        mobj_new_chase_dir(mobj)
    }
    if mobj["movedir"] != DI_NODIR {
        const speed = mobj["speed"]
        const dir = mobj["movedir"]
        if dir < 8 {
            mobj["momx"] = fixed_mul(speed, xspeed[dir])
            mobj["momy"] = fixed_mul(speed, yspeed[dir])
        }
    }
}

func a_face_target(mobj) {
    mobj["angle"] = point_to_angle_2(mobj["x"], mobj["y"], player_x, player_y)
}

func a_pos_attack(mobj) {
    a_face_target(mobj)
    const damage = (random_int(5) + 1) * 3
    p_line_attack(mobj, mobj["angle"], MISSILERANGE, 0, damage)
}

func a_spos_attack(mobj) {
    a_face_target(mobj)
    let i = 0
    while i < 3 {
        const angle = mobj["angle"] + ((random_int(256) - 128) << 18)
        const damage = (random_int(5) + 1) * 3
        p_line_attack(mobj, angle, MISSILERANGE, 0, damage)
        i = i + 1
    }
}

func a_troop_attack(mobj) {
    a_face_target(mobj)
    const dist = point_to_dist(mobj["x"], mobj["y"], player_x, player_y)
    if dist < MELEERANGE {
        const damage = (random_int(8) + 1) * 3
        player_damage(damage, mobj)
    } else {
        p_spawn_missile(mobj, "MT_TROOPSHOT")
    }
}

