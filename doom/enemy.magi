func a_tracer(actor) {
    // Revenant homing missile tracking
    if actor["target"] == null { return }
    const exact = point_to_angle_2(actor["x"], actor["y"], player_x, player_y)
    let diff = exact - actor["angle"]
    while diff > ANG180 { diff = diff - ANG360 }
    while diff < -ANG180 { diff = diff + ANG360 }
    const turn_amount = ANG45 / 16
    if diff > 0 {
        if diff > turn_amount { actor["angle"] = actor["angle"] + turn_amount }
        else { actor["angle"] = exact }
    } else {
        if diff < -turn_amount { actor["angle"] = actor["angle"] - turn_amount }
        else { actor["angle"] = exact }
    }
    const speed = actor["speed"]
    actor["momx"] = fixed_mul(speed, fine_cosine(actor["angle"]))
    actor["momy"] = fixed_mul(speed, fine_sine(actor["angle"]))
}

func check_sight(actor) {
    if player_dead { return false }
    if actor["sector"] != null && player_sector != null {
        if map_check_reject(actor["sector"]["index"], player_sector["index"]) { return false }
    }
    const dist = point_to_dist(actor["x"], actor["y"], player_x, player_y)
    if dist > 2048 * FRACUNIT { return false }
    true
}

func p_move(actor) {
    if actor["movedir"] == DI_NODIR { return false }
    if actor["movedir"] >= 8 { return false }
    const speed = actor["speed"]
    const tryx = actor["x"] + fixed_mul(speed, xspeed[actor["movedir"]])
    const tryy = actor["y"] + fixed_mul(speed, yspeed[actor["movedir"]])
    if p_try_move_mobj(actor, tryx, tryy) {
        actor["x"] = tryx
        actor["y"] = tryy
        return true
    }
    if (actor["flags"] & MF_FLOAT) != 0 && p_check_float(actor) {
        return true
    }
    false
}

func p_try_move_mobj(actor, newx, newy) {
    const radius = actor["radius"]
    let i = 0
    while i < map_num_linedefs {
        const line = map_linedefs[i]
        if newx + radius < line["bbox"]["left"] || newx - radius > line["bbox"]["right"] ||
           newy + radius < line["bbox"]["bottom"] || newy - radius > line["bbox"]["top"] {
            i = i + 1; continue
        }
        const side1 = point_on_side(actor["x"], actor["y"], line["v1"]["x"], line["v1"]["y"], line["dx"], line["dy"])
        const side2 = point_on_side(newx, newy, line["v1"]["x"], line["v1"]["y"], line["dx"], line["dy"])
        if side1 == side2 { i = i + 1; continue }
        if (line["flags"] & ML_BLOCKING) != 0 { return false }
        if (line["flags"] & ML_BLOCKMONSTERS) != 0 { return false }
        if line["backsector"] == null { return false }
        const front = line["frontsector"]
        const back = line["backsector"]
        if front == null || back == null { return false }
        const opening_floor = if back["floorheight"] > front["floorheight"] { back["floorheight"] } else { front["floorheight"] }
        const opening_ceil = if back["ceilingheight"] < front["ceilingheight"] { back["ceilingheight"] } else { front["ceilingheight"] }
        if opening_ceil - opening_floor < actor["height"] { return false }
        if opening_floor - actor["z"] > 24 * FRACUNIT { return false }
        if line["special"] != 0 { doors_walk_line(line) }
        i = i + 1
    }
    true
}

func p_check_float(actor) {
    const dz = player_z - actor["z"]
    if dz > 0 { actor["z"] = actor["z"] + FLOATSPEED }
    if dz < 0 { actor["z"] = actor["z"] - FLOATSPEED }
    true
}

func p_new_chase_dir(actor) {
    if actor["target"] == null { return }
    const dx = player_x - actor["x"]
    const dy = player_y - actor["y"]
    let d1 = DI_NODIR
    let d2 = DI_NODIR
    let tdir = DI_NODIR
    if dx > 10 * FRACUNIT { d1 = DI_EAST }
    else if dx < -10 * FRACUNIT { d1 = DI_WEST }
    if dy > 10 * FRACUNIT { d2 = DI_NORTH }
    else if dy < -10 * FRACUNIT { d2 = DI_SOUTH }
    if d1 != DI_NODIR && d2 != DI_NODIR {
        const idx = (if d2 == DI_NORTH { 0 } else { 2 }) + (if d1 == DI_EAST { 0 } else { 1 })
        actor["movedir"] = diags[idx]
        if p_try_walk(actor) { return }
    }
    if random_int(256) > 200 || abs(dy) > abs(dx) {
        const tmp = d1; d1 = d2; d2 = tmp
    }
    if d1 != DI_NODIR {
        actor["movedir"] = d1
        if p_try_walk(actor) { return }
    }
    if d2 != DI_NODIR {
        actor["movedir"] = d2
        if p_try_walk(actor) { return }
    }
    if actor["movedir"] != DI_NODIR {
        const old = actor["movedir"]
        actor["movedir"] = old
        if p_try_walk(actor) { return }
    }
    tdir = 0
    while tdir < 8 {
        if tdir != opposite[actor["movedir"]] {
            actor["movedir"] = tdir
            if p_try_walk(actor) { return }
        }
        tdir = tdir + 1
    }
    if opposite[actor["movedir"]] != DI_NODIR {
        actor["movedir"] = opposite[actor["movedir"]]
        if p_try_walk(actor) { return }
    }
    actor["movedir"] = DI_NODIR
}

func p_try_walk(actor) {
    if !p_move(actor) { return false }
    actor["movecount"] = random_int(16)
    true
}

func p_line_attack(source, angle, range, slope, damage) {
    const cos_a = fine_cosine(angle)
    const sin_a = fine_sine(angle)
    const dist = point_to_dist(source["x"], source["y"], player_x, player_y)
    if dist < range {
        const ang_to_player = point_to_angle_2(source["x"], source["y"], player_x, player_y)
        let diff = ang_to_player - angle
        while diff > ANG180 { diff = diff - ANG360 }
        while diff < -ANG180 { diff = diff + ANG360 }
        if abs(diff) < ANG45 / 2 {
            player_damage(damage, source)
        }
    }
    for mobj in mobj_list {
        if (mobj["flags"] & MF_SHOOTABLE) == 0 { continue }
        if mobj["health"] <= 0 { continue }
        if mobj == source { continue }
        const d = point_to_dist(source["x"], source["y"], mobj["x"], mobj["y"])
        if d >= range { continue }
        const a = point_to_angle_2(source["x"], source["y"], mobj["x"], mobj["y"])
        let adiff = a - angle
        while adiff > ANG180 { adiff = adiff - ANG360 }
        while adiff < -ANG180 { adiff = adiff + ANG360 }
        const half_a = point_to_angle_2(0, 0, d, mobj["radius"])
        if abs(adiff) < half_a {
            mobj_damage(mobj, null, source, damage)
        }
    }
}

const MT_TROOPSHOT = 10001
const MT_HEADSHOT = 10002
const MT_BRUISERSHOT = 10003
const MT_ROCKET = 10004
const MT_ARACHPLAZ = 10005
const MT_TRACER = 10006
const MT_FATSHOT = 10007

func p_spawn_missile_type(source, mtype) {
    const angle = source["angle"]
    const speed = 20 * FRACUNIT
    const missile = mobj_spawn(
        source["x"] + fixed_mul(32 * FRACUNIT, fine_cosine(angle)),
        source["y"] + fixed_mul(32 * FRACUNIT, fine_sine(angle)),
        0
    )
    if missile != null {
        missile["momx"] = fixed_mul(speed, fine_cosine(angle))
        missile["momy"] = fixed_mul(speed, fine_sine(angle))
        missile["flags"] = MF_MISSILE | MF_NOBLOCKMAP | MF_NOGRAVITY
        missile["angle"] = angle
        missile["type"] = mtype
        const dist = point_to_dist(source["x"], source["y"], player_x, player_y)
        const dz = player_viewz - source["z"]
        if dist > 0 {
            missile["momz"] = fixed_div(dz, dist >> (FRACBITS - 3))
        }
    }
}

func player_mobj_ref() {
    {"type": "player", "x": player_x, "y": player_y, "z": player_z, "health": player_health, "radius": 16 * FRACUNIT, "height": 56 * FRACUNIT}
}

func door_open_tagged(tag) {
    for sector in map_sectors {
        if sector["tag"] == tag {
            door_open_sector(sector, VDOORSPEED, -1)
        }
    }
}

func floor_lower_to_lowest_tagged(tag) {
    for sector in map_sectors {
        if sector["tag"] == tag {
            const target = find_lowest_floor_around(sector)
            door_thinkers.push({
                "type": "floor",
                "sector": sector,
                "speed": FRACUNIT,
                "target": target,
                "direction": -1
            })
        }
    }
}
