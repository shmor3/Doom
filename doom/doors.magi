// doors.magi -- Complete Doom linedef specials handler
// Faithful reimplementation of linuxdoom-1.10:
//   p_spec.c, p_doors.c, p_plats.c, p_floor.c, p_ceilng.c, p_lights.c, p_telept.c
//
// All ~140 linedef special types with proper trigger types:
//   W1 = walk once, WR = walk repeatable
//   S1 = switch once, SR = switch repeatable
//   G1 = gun (shoot) once, GR = gun repeatable

// ---------------------------------------------------------------------------
// Thinker storage
// ---------------------------------------------------------------------------
let door_thinkers = []

// ---------------------------------------------------------------------------
// Speed / timing constants (fixed-point)
// ---------------------------------------------------------------------------
const VDOORSPEED     = 2 * FRACUNIT
const VDOORWAIT      = 150
const BLAZESPEED     = 4 * VDOORSPEED
const BLAZEWAIT      = 15
const PLATSPEED      = FRACUNIT
const PLATWAIT       = 105
const FLOORSPEED     = FRACUNIT
const CEILSPEED      = FRACUNIT
const STAIRSPEED     = 2 * FRACUNIT / 4       // Slow stairs (Raise 8)
const TURBOSPEED     = 4 * FRACUNIT            // Turbo stairs (Raise 16)

const STAIRHEIGHT_8  = 8 * FRACUNIT
const STAIRHEIGHT_16 = 16 * FRACUNIT

const CRUSHSPEED     = FRACUNIT

// ---------------------------------------------------------------------------
// Initialization
// ---------------------------------------------------------------------------
func doors_init() {
    door_thinkers = []
}

// ---------------------------------------------------------------------------
// Sector search helpers
// ---------------------------------------------------------------------------
func find_tagged_sector(tag) {
    if tag == 0 { return null }
    let _fti = 0
    while _fti < len(map_sectors) {
        const sector = map_sectors[_fti]
        _fti = _fti + 1
        if sector["tag"] == tag { return sector }
    }
    null
}

func find_all_tagged_sectors(tag) {
    let result = []
    if tag == 0 { return result }
    let _fai = 0
    while _fai < len(map_sectors) {
        const sector = map_sectors[_fai]
        _fai = _fai + 1
        if sector["tag"] == tag { result.push(sector) }
    }
    result
}

func find_lowest_ceiling_around(sector) {
    let lowest = 32767 << FRACBITS
    let _lci = 0
    while _lci < len(map_linedefs) {
        const line = map_linedefs[_lci]
        _lci = _lci + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["ceilingheight"] < lowest {
                lowest = line["backsector"]["ceilingheight"]
            }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["ceilingheight"] < lowest {
                lowest = line["frontsector"]["ceilingheight"]
            }
        }
    }
    lowest
}

func find_highest_ceiling_around(sector) {
    let highest = -32767 << FRACBITS
    let _hci = 0
    while _hci < len(map_linedefs) {
        const line = map_linedefs[_hci]
        _hci = _hci + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["ceilingheight"] > highest {
                highest = line["backsector"]["ceilingheight"]
            }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["ceilingheight"] > highest {
                highest = line["frontsector"]["ceilingheight"]
            }
        }
    }
    highest
}

func find_lowest_floor_around(sector) {
    let lowest = sector["floorheight"]
    let _lfi = 0
    while _lfi < len(map_linedefs) {
        const line = map_linedefs[_lfi]
        _lfi = _lfi + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["floorheight"] < lowest { lowest = line["backsector"]["floorheight"] }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["floorheight"] < lowest { lowest = line["frontsector"]["floorheight"] }
        }
    }
    lowest
}

func find_highest_floor_around(sector) {
    let highest = -32767 << FRACBITS
    let _hfi = 0
    while _hfi < len(map_linedefs) {
        const line = map_linedefs[_hfi]
        _hfi = _hfi + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["floorheight"] > highest { highest = line["backsector"]["floorheight"] }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["floorheight"] > highest { highest = line["frontsector"]["floorheight"] }
        }
    }
    highest
}

func find_next_highest_floor(sector, current_height) {
    let best = 32767 << FRACBITS
    let found = false
    let _nhi = 0
    while _nhi < len(map_linedefs) {
        const line = map_linedefs[_nhi]
        _nhi = _nhi + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            const h = line["backsector"]["floorheight"]
            if h > current_height && h < best { best = h; found = true }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            const h = line["frontsector"]["floorheight"]
            if h > current_height && h < best { best = h; found = true }
        }
    }
    if found { best } else { current_height }
}

func find_next_lowest_floor(sector, current_height) {
    let best = -32767 << FRACBITS
    let found = false
    let _nli = 0
    while _nli < len(map_linedefs) {
        const line = map_linedefs[_nli]
        _nli = _nli + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            const h = line["backsector"]["floorheight"]
            if h < current_height && h > best { best = h; found = true }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            const h = line["frontsector"]["floorheight"]
            if h < current_height && h > best { best = h; found = true }
        }
    }
    if found { best } else { current_height }
}

func find_shortest_texture_around(sector) {
    let min_tex = 32767 << FRACBITS
    let _sti = 0
    while _sti < len(map_linedefs) {
        const line = map_linedefs[_sti]
        _sti = _sti + 1
        let is_adj = false
        if line["frontsector"] == sector { is_adj = true }
        if line["backsector"] == sector { is_adj = true }
        if !is_adj { continue }
        if line["front"] != null {
            const side = line["front"]
            if side["bottomtexture"] != "-" && side["bottomtexture"] != "" {
                const h = texture_height_for_name(side["bottomtexture"])
                if h > 0 && h < min_tex { min_tex = h }
            }
        }
        if line["back"] != null {
            const side = line["back"]
            if side["bottomtexture"] != "-" && side["bottomtexture"] != "" {
                const h = texture_height_for_name(side["bottomtexture"])
                if h > 0 && h < min_tex { min_tex = h }
            }
        }
    }
    min_tex
}

func texture_height_for_name(name) {
    // Default texture height estimate - 128 units is standard Doom texture height
    128 * FRACUNIT
}

func find_min_surrounding_light(sector, min_val) {
    let result = min_val
    let _mli = 0
    while _mli < len(map_linedefs) {
        const line = map_linedefs[_mli]
        _mli = _mli + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["lightlevel"] < result {
                result = line["backsector"]["lightlevel"]
            }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["lightlevel"] < result {
                result = line["frontsector"]["lightlevel"]
            }
        }
    }
    result
}

func find_max_surrounding_light(sector, max_val) {
    let result = max_val
    let _xli = 0
    while _xli < len(map_linedefs) {
        const line = map_linedefs[_xli]
        _xli = _xli + 1
        if line["frontsector"] == sector && line["backsector"] != null {
            if line["backsector"]["lightlevel"] > result {
                result = line["backsector"]["lightlevel"]
            }
        }
        if line["backsector"] == sector && line["frontsector"] != null {
            if line["frontsector"]["lightlevel"] > result {
                result = line["frontsector"]["lightlevel"]
            }
        }
    }
    result
}

func find_sector_from_line_tag(line, start_idx) {
    // Find next sector with matching tag after start_idx
    let i = start_idx + 1
    while i < len(map_sectors) {
        if map_sectors[i]["tag"] == line["tag"] { return i }
        i = i + 1
    }
    -1
}

func get_sector_neighbor(sector, line) {
    // Return the sector on the other side of this line relative to sector
    if line["frontsector"] == sector { return line["backsector"] }
    if line["backsector"] == sector { return line["frontsector"] }
    null
}

func sector_has_active_thinker(sector, thinker_type) {
    let _ati = 0
    while _ati < len(door_thinkers) {
        const t = door_thinkers[_ati]
        _ati = _ati + 1
        if t["sector"] == sector && t["type"] == thinker_type { return true }
    }
    false
}

// ---------------------------------------------------------------------------
// DISPATCH: Use (switch / push)
// ---------------------------------------------------------------------------
func doors_use_line(line, side) {
    const special = line["special"]
    if special == 0 { return }

    match special {
        // -- Doors: S1 / SR --
        1   => ev_do_door_normal(line, false),               // S1 Door Open Wait Close
        26  => ev_do_locked_door(line, it_bluecard, it_blueskull, false),   // S1 DR Blue
        27  => ev_do_locked_door(line, it_yellowcard, it_yellowskull, false), // S1 DR Yellow
        28  => ev_do_locked_door(line, it_redcard, it_redskull, false),     // S1 DR Red
        31  => ev_do_door_open(line, false),                  // S1 Door Open Stay
        32  => ev_do_locked_door_open(line, it_bluecard, it_blueskull),     // S1 D1 Blue Open Stay
        33  => ev_do_locked_door_open(line, it_redcard, it_redskull),       // S1 D1 Red Open Stay
        34  => ev_do_locked_door_open(line, it_yellowcard, it_yellowskull), // S1 D1 Yellow Open Stay
        29  => ev_do_door_normal(line, true),                 // S1 Door Open Wait Close (tag)
        50  => ev_do_door_close(line),                        // S1 Door Close
        42  => ev_do_door_close(line),                        // SR Door Close
        61  => ev_do_door_open(line, false),                  // SR Door Open Stay
        63  => ev_do_door_normal(line, true),                 // SR Door Open Wait Close
        103 => ev_do_door_open(line, true),                   // S1 Door Open Stay (tag)
        46  => ev_do_door_open_grating(line),                 // GR Door Open Stay (gun)
        76  => ev_do_door_close_30_open(line),                // SR Door Close 30 Open

        // -- Doors: Blazing --
        99  => ev_do_locked_door_blaze(line, it_bluecard, it_blueskull),   // SR Blaze Lock Blue
        134 => ev_do_locked_door_blaze(line, it_redcard, it_redskull),     // SR Blaze Lock Red
        136 => ev_do_locked_door_blaze(line, it_yellowcard, it_yellowskull), // SR Blaze Lock Yellow
        133 => ev_do_locked_door_blaze_open(line, it_bluecard, it_blueskull),   // S1 Blaze Lock Blue Open
        135 => ev_do_locked_door_blaze_open(line, it_redcard, it_redskull),     // S1 Blaze Lock Red Open
        137 => ev_do_locked_door_blaze_open(line, it_yellowcard, it_yellowskull), // S1 Blaze Lock Yellow Open
        111 => ev_do_door_blaze_normal(line),                 // S1 Blazing Door Open Wait Close
        112 => ev_do_door_blaze_normal(line),                 // SR Blazing Door Open Wait Close
        113 => ev_do_door_blaze_open(line),                   // S1 Blazing Door Open Stay
        114 => ev_do_door_blaze_open(line),                   // SR Blazing Door Open Stay
        115 => ev_do_door_blaze_normal(line),                 // S1 Blazing Door Open Wait Close (tag)
        116 => ev_do_door_blaze_normal(line),                 // SR Blazing Door Open Wait Close (tag)
        117 => ev_do_door_blaze_open(line),                   // S1 Blazing Door Open Stay (tag)
        118 => ev_do_door_blaze_open(line),                   // SR Blazing Door Open Stay (tag)

        // -- Lifts / Platforms --
        21  => ev_do_plat_down_wait_up(line, PLATWAIT),       // S1 Lift Lower Wait Raise
        62  => ev_do_plat_down_wait_up(line, PLATWAIT),       // SR Lift Lower Wait Raise
        122 => ev_do_plat_down_wait_up(line, PLATWAIT),       // S1 Lift Lower Wait Raise (blazing)
        123 => ev_do_plat_down_wait_up(line, PLATWAIT),       // SR Lift Lower Wait Raise (blazing)
        15  => ev_do_plat_raise_24_change(line),              // S1 Plat Raise 24 Change Texture
        66  => ev_do_plat_raise_24_change(line),              // SR Plat Raise 24 Change Texture
        14  => ev_do_plat_raise_32_change(line),              // S1 Plat Raise 32 Change Texture
        67  => ev_do_plat_raise_32_change(line),              // SR Plat Raise 32 Change Texture
        20  => ev_do_plat_raise_next_change(line),            // S1 Plat Raise Next Floor Change Texture
        68  => ev_do_plat_raise_next_change(line),            // SR Plat Raise Next Floor Change Texture
        47  => ev_do_plat_raise_next_change(line),            // G1 Plat Raise Next Floor Change Texture
        143 => ev_do_plat_raise_24_change(line),              // W1 Plat Raise 24 Change Texture (actually floor, shares impl)
        148 => ev_do_plat_raise_32_change(line),              // W1 Plat Raise 32 Change Texture

        // -- Floors --
        23  => ev_do_floor_lower_to_lowest(line),             // S1 Floor Lower to Lowest
        60  => ev_do_floor_lower_to_lowest(line),             // SR Floor Lower to Lowest
        45  => ev_do_floor_lower_to_highest(line),            // SR Floor Lower to Surrounding
        102 => ev_do_floor_lower_to_highest(line),            // S1 Floor Lower to Surrounding
        55  => ev_do_floor_raise_crush(line),                 // S1 Floor Raise to Lowest Ceiling Crush
        65  => ev_do_floor_raise_crush(line),                 // SR Floor Raise to Lowest Ceiling Crush
        18  => ev_do_floor_raise_to_next(line),               // S1 Floor Raise to Next Higher Floor
        69  => ev_do_floor_raise_to_next(line),               // SR Floor Raise to Next Higher Floor
        71  => ev_do_floor_turbo_lower(line),                 // S1 Floor Lower to 8 Above Highest
        98  => ev_do_floor_turbo_lower(line),                 // SR Floor Lower to 8 Above Highest
        64  => ev_do_floor_raise_crush(line),                 // SR Floor Raise to Ceiling Crush
        101 => ev_do_floor_raise_to_lowest_ceiling(line),     // S1 Floor Raise to Lowest Ceiling
        91  => ev_do_floor_raise_to_lowest_ceiling(line),     // W1 Floor Raise to Lowest Ceiling (handled in walk too)
        131 => ev_do_floor_raise_turbo(line),                 // S1 Floor Raise Turbo
        132 => ev_do_floor_raise_turbo(line),                 // SR Floor Raise Turbo
        140 => ev_do_floor_raise_512(line),                   // S1 Floor Raise 512
        58  => ev_do_floor_raise_24(line),                    // W1 Floor Raise 24 (also handled in walk)
        59  => ev_do_floor_raise_24_change(line),             // W1 Floor Raise 24 Change (also handled in walk)
        176 => ev_do_floor_raise_to_next(line),               // SR Floor Raise to Next Higher

        // -- Ceilings --
        43  => ev_do_ceiling_lower_to_floor(line),            // SR Ceiling Lower to Floor
        44  => ev_do_ceiling_lower_to_floor_plus_8(line),     // W1 Ceiling Lower to Floor +8
        40  => ev_do_ceiling_raise_to_highest(line),          // W1 Ceiling Raise to Highest (also walk)
        41  => ev_do_ceiling_lower_to_floor(line),            // S1 Ceiling Lower to Floor

        // -- Crushers --
        49  => ev_do_crusher_slow(line),                      // S1 Crusher Slow
        73  => ev_do_crusher_slow_perpetual(line),            // WR Crusher Slow (perpetual)
        77  => ev_do_crusher_fast(line),                      // WR Crusher Fast (perpetual)
        57  => ev_do_crusher_stop(line),                      // W1 Crusher Stop
        74  => ev_do_crusher_stop(line),                      // WR Crusher Stop
        141 => ev_do_crusher_silent(line),                    // W1 Crusher Silent

        // -- Stairs --
        7   => ev_build_stairs_8(line),                       // S1 Build Stairs 8
        127 => ev_build_stairs_turbo(line),                   // S1 Build Stairs Turbo 16

        // -- Lights --
        35  => ev_do_light_off(line),                         // W1 Lights to 35
        104 => ev_do_light_off(line),                         // W1 Lights to Minimum Surrounding
        12  => ev_do_light_brightest(line),                   // W1 Lights to Brightest
        13  => ev_do_light_brightest(line),                   // W1 Lights to 255
        17  => ev_start_light_strobing(line),                 // W1 Light Blink 1.0 sec
        138 => ev_do_light_on_255(line),                      // SR Light On 255

        // -- Donuts --
        9   => ev_do_donut(line),                             // S1 Donut

        // -- Teleport --
        // (teleport on use is unusual but type 174 exists in Boom; Doom uses walk)

        // -- Exit --
        11  => ev_do_exit(line),                              // S1 Exit Level
        51  => ev_do_secret_exit(line),                       // S1 Secret Exit
        52  => ev_do_exit(line),                              // W1 Exit Level (also walk)
        124 => ev_do_secret_exit(line),                       // W1 Secret Exit (also walk)

        _ => {}
    }

    // Clear one-shot specials (S1 / G1)
    match special {
        1 | 7 | 9 | 11 | 14 | 15 | 18 | 20 | 21 | 23 | 26 | 27 | 28 |
        29 | 31 | 32 | 33 | 34 | 41 | 49 | 50 | 51 | 55 | 71 | 99 |
        101 | 102 | 103 | 111 | 113 | 115 | 117 | 122 | 127 | 131 |
        133 | 135 | 137 | 140 => {
            line["special"] = 0
        },
        _ => {}
    }
}

// ---------------------------------------------------------------------------
// DISPATCH: Walk (player crosses line)
// ---------------------------------------------------------------------------
func doors_walk_line(line) {
    const special = line["special"]
    if special == 0 { return }

    match special {
        // -- Doors: W1 / WR --
        2   => ev_do_door_open(line, true),                   // W1 Door Open Stay
        3   => ev_do_door_close(line),                        // W1 Door Close
        4   => ev_do_door_normal(line, true),                 // W1 Door Open Wait Close
        16  => ev_do_door_close_30_open(line),                // W1 Door Close 30 Open
        75  => ev_do_door_close(line),                        // WR Door Close
        76  => ev_do_door_close_30_open(line),                // WR Door Close 30 Open
        86  => ev_do_door_open(line, true),                   // WR Door Open Stay
        90  => ev_do_door_normal(line, true),                 // WR Door Open Wait Close
        105 => ev_do_door_blaze_normal(line),                 // WR Blazing Door Open Wait Close
        106 => ev_do_door_blaze_open(line),                   // WR Blazing Door Open Stay
        107 => ev_do_door_blaze_close(line),                  // WR Blazing Door Close
        108 => ev_do_door_blaze_normal(line),                 // W1 Blazing Door Open Wait Close
        109 => ev_do_door_blaze_open(line),                   // W1 Blazing Door Open Stay
        110 => ev_do_door_blaze_close(line),                  // W1 Blazing Door Close

        // -- Lifts / Platforms: W1 / WR --
        10  => ev_do_plat_down_wait_up(line, PLATWAIT),       // W1 Lift Lower Wait Raise
        22  => ev_do_plat_raise_next_change(line),            // W1 Plat Raise Next Floor Change Texture
        53  => ev_do_plat_perpetual_raise(line),              // W1 Perpetual Platform Raise
        54  => ev_do_plat_stop(line),                         // W1 Platform Stop
        87  => ev_do_plat_perpetual_raise(line),              // WR Perpetual Platform Raise
        88  => ev_do_plat_down_wait_up(line, PLATWAIT),       // WR Lift Lower Wait Raise
        89  => ev_do_plat_stop(line),                         // WR Platform Stop
        120 => ev_do_plat_down_wait_up_blaze(line),           // WR Blazing Lift Lower Wait Raise
        121 => ev_do_plat_down_wait_up_blaze(line),           // W1 Blazing Lift Lower Wait Raise

        // -- Floors: W1 / WR --
        5   => ev_do_floor_raise_to_lowest_ceiling(line),     // W1 Floor Raise to Lowest Ceiling
        19  => ev_do_floor_lower_to_highest(line),            // W1 Floor Lower to Highest
        24  => ev_do_floor_raise_crush(line),                 // G1 Floor Raise to Lowest Ceiling Crush
        30  => ev_do_floor_raise_by_shortest_tex(line),       // W1 Floor Raise Shortest Texture
        36  => ev_do_floor_turbo_lower(line),                 // W1 Floor Lower to 8 Above Highest
        37  => ev_do_floor_lower_to_lowest_change(line),      // W1 Floor Lower to Lowest Change Texture
        38  => ev_do_floor_lower_to_lowest(line),             // W1 Floor Lower to Lowest
        56  => ev_do_floor_raise_crush(line),                 // W1 Floor Raise to 8 Below Ceiling Crush
        58  => ev_do_floor_raise_24(line),                    // W1 Floor Raise 24
        59  => ev_do_floor_raise_24_change(line),             // W1 Floor Raise 24 Change Texture
        82  => ev_do_floor_lower_to_lowest(line),             // WR Floor Lower to Lowest
        83  => ev_do_floor_lower_to_highest(line),            // WR Floor Lower to Highest
        84  => ev_do_floor_lower_to_lowest_change(line),      // WR Floor Lower to Lowest Change Texture
        91  => ev_do_floor_raise_to_lowest_ceiling(line),     // W1 Floor Raise to Lowest Ceiling
        92  => ev_do_floor_raise_24(line),                    // WR Floor Raise 24
        93  => ev_do_floor_raise_24_change(line),             // WR Floor Raise 24 Change Texture
        94  => ev_do_floor_raise_crush(line),                 // WR Floor Raise to Ceiling Crush
        95  => ev_do_floor_raise_to_next(line),               // WR Floor Raise to Next Higher
        96  => ev_do_floor_raise_by_shortest_tex(line),       // WR Floor Raise Shortest Texture
        119 => ev_do_floor_raise_to_next(line),               // W1 Floor Raise to Next Higher
        128 => ev_do_floor_raise_to_next(line),               // WR Floor Raise to Next Higher
        129 => ev_do_floor_raise_turbo(line),                 // WR Floor Raise Turbo
        130 => ev_do_floor_raise_turbo(line),                 // W1 Floor Raise Turbo
        142 => ev_do_floor_raise_512(line),                   // W1 Floor Raise 512

        // -- Ceilings: W1 / WR --
        40  => ev_do_ceiling_raise_to_highest(line),          // W1 Ceiling Raise to Highest
        44  => ev_do_ceiling_lower_to_floor_plus_8(line),     // W1 Ceiling Lower to Floor +8
        72  => ev_do_ceiling_lower_to_floor_plus_8(line),     // WR Ceiling Lower to Floor +8

        // -- Crushers: W1 / WR --
        6   => ev_do_crusher_fast_perpetual(line),            // W1 Fast Crusher Start
        25  => ev_do_crusher_slow_perpetual(line),            // W1 Crusher Slow (perpetual)
        57  => ev_do_crusher_stop(line),                      // W1 Crusher Stop
        73  => ev_do_crusher_slow_perpetual(line),            // WR Crusher Slow (perpetual)
        74  => ev_do_crusher_stop(line),                      // WR Crusher Stop
        77  => ev_do_crusher_fast_perpetual(line),            // WR Crusher Fast (perpetual)
        141 => ev_do_crusher_silent(line),                    // W1 Crusher Silent

        // -- Stairs: W1 / WR --
        8   => ev_build_stairs_8(line),                       // W1 Build Stairs 8
        100 => ev_build_stairs_turbo(line),                   // W1 Build Stairs Turbo 16
        256 => ev_build_stairs_8(line),                       // WR Build Stairs 8 (Boom extension placeholder)
        257 => ev_build_stairs_turbo(line),                   // WR Build Stairs Turbo 16 (Boom extension placeholder)

        // -- Lights: W1 / WR --
        12  => ev_do_light_brightest(line),                   // W1 Lights to Brightest Surrounding
        13  => ev_do_light_on_255(line),                      // W1 Lights to 255
        17  => ev_start_light_strobing(line),                 // W1 Light Start Blinking
        35  => ev_do_light_off(line),                         // W1 Lights to 35
        79  => ev_do_light_off(line),                         // WR Lights to 35
        80  => ev_do_light_brightest(line),                   // WR Lights to Brightest
        81  => ev_do_light_on_255(line),                      // WR Lights to 255
        104 => ev_do_light_min_surrounding(line),             // W1 Lights to Minimum Surrounding

        // -- Teleporters: W1 / WR --
        39  => ev_do_teleport(line),                          // W1 Teleport
        97  => ev_do_teleport(line),                          // WR Teleport
        125 => ev_do_teleport_monsters_only(line),            // W1 Teleport Monsters Only
        126 => ev_do_teleport_monsters_only(line),            // WR Teleport Monsters Only

        // -- Donuts --
        146 => ev_do_donut(line),                             // W1 Donut (Boom-style; original uses S1=9)

        // -- Exit: W1 --
        52  => ev_do_exit(line),                              // W1 Exit Level
        124 => ev_do_secret_exit(line),                       // W1 Secret Exit

        _ => {}
    }

    // Clear one-shot specials (W1)
    match special {
        2 | 3 | 4 | 5 | 6 | 8 | 10 | 16 | 19 | 22 | 25 | 30 | 36 | 37 | 38 |
        39 | 40 | 44 | 52 | 53 | 54 | 56 | 57 | 58 | 59 | 91 | 100 |
        104 | 108 | 109 | 110 | 119 | 120 | 121 | 124 | 125 | 130 |
        141 | 142 => {
            line["special"] = 0
        },
        _ => {}
    }
}

// ---------------------------------------------------------------------------
// DISPATCH: Shoot (gun triggers)
// ---------------------------------------------------------------------------
func doors_shoot_line(line) {
    const special = line["special"]
    if special == 0 { return }

    match special {
        // -- Gun specials (G1 / GR) --
        24  => ev_do_floor_raise_crush(line),                 // G1 Floor Raise to Lowest Ceiling Crush
        46  => ev_do_door_open_grating(line),                 // GR Door Open Stay (repeatable)
        47  => ev_do_plat_raise_next_change(line),            // G1 Plat Raise Next Floor Change Texture

        _ => {}
    }

    // Clear one-shot gun specials (G1)
    match special {
        24 | 47 => {
            line["special"] = 0
        },
        _ => {}
    }
}

// ===========================================================================
// DOOR IMPLEMENTATIONS (p_doors.c)
// ===========================================================================

// Standard door: opens, waits, closes. Used by manual (tag 0) or tagged doors.
func ev_do_door_normal(line, use_tag) {
    const sectors = if use_tag { find_all_tagged_sectors(line["tag"]) } else { [] }
    if len(sectors) == 0 && line["backsector"] != null {
        do_door_for_sector(line["backsector"], VDOORSPEED, VDOORWAIT)
        return
    }
    let _dni = 0
    while _dni < len(sectors) {
        const sec = sectors[_dni]
        _dni = _dni + 1
        if sector_has_active_thinker(sec, "door") { continue }
        do_door_for_sector(sec, VDOORSPEED, VDOORWAIT)
    }
}

// Door opens and stays open
func ev_do_door_open(line, use_tag) {
    const sectors = if use_tag { find_all_tagged_sectors(line["tag"]) } else { [] }
    if len(sectors) == 0 && line["backsector"] != null {
        do_door_for_sector(line["backsector"], VDOORSPEED, -1)
        return
    }
    let _doi = 0
    while _doi < len(sectors) {
        const sec = sectors[_doi]
        _doi = _doi + 1
        if sector_has_active_thinker(sec, "door") { continue }
        do_door_for_sector(sec, VDOORSPEED, -1)
    }
}

// Door opens (gun-activated grating, GR type 46)
func ev_do_door_open_grating(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    if len(sectors) == 0 && line["backsector"] != null {
        do_door_for_sector(line["backsector"], VDOORSPEED, -1)
        return
    }
    let _dgi = 0
    while _dgi < len(sectors) {
        const sec = sectors[_dgi]
        _dgi = _dgi + 1
        if sector_has_active_thinker(sec, "door") { continue }
        do_door_for_sector(sec, VDOORSPEED, -1)
    }
}

// Door closes
func ev_do_door_close(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _dci = 0
    while _dci < len(sectors) {
        const sec = sectors[_dci]
        _dci = _dci + 1
        if sector_has_active_thinker(sec, "door") { continue }
        const floor = sec["floorheight"]
        door_thinkers.push({
            "type": "door",
            "sector": sec,
            "direction": -1,
            "speed": VDOORSPEED,
            "topheight": sec["ceilingheight"],
            "topcountdown": 0,
            "phase": "closing",
            "bottomheight": floor
        })
    }
}

// Door closes, waits 30 seconds, then opens
func ev_do_door_close_30_open(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
