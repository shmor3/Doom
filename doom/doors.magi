// ===========================================================================
// SECTOR-BASED LIGHT EFFECTS (spawned from map sector specials)
// ===========================================================================

// Called during map load to set up sector-based light effects
func doors_spawn_sector_specials() {
    let _sspi = 0
    while _sspi < len(map_sectors) {
        const sec = map_sectors[_sspi]
        _sspi = _sspi + 1
        match sec["special"] {
            1 => {
                // Light Blink Random
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "blink",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": (random_int(7) + 1) * TICRATE,
                    "phase": "bright"
                })
            },
            2 => {
                // Light Blink 0.5 sec
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "strobe",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": 0,
                    "darktime": 15,
                    "brighttime": 5,
                    "phase": "bright"
                })
            },
            3 => {
                // Light Blink 1.0 sec
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "strobe",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": 0,
                    "darktime": 35,
                    "brighttime": 5,
                    "phase": "bright"
                })
            },
            4 => {
                // -20% Damage and Light Blink 0.5 sec (Nukage)
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "strobe",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": 0,
                    "darktime": 15,
                    "brighttime": 5,
                    "phase": "bright"
                })
                // Damage handled in sector damage thinker
            },
            8 => {
                // Light Glowing (oscillate between min and max)
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "glow",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "direction": -1
                })
            },
            12 => {
                // Light Blink 0.5 sec, sync
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "strobe",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": 15,
                    "darktime": 15,
                    "brighttime": 5,
                    "phase": "bright"
                })
            },
            13 => {
                // Light Blink 1.0 sec, sync
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "strobe",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": 35,
                    "darktime": 35,
                    "brighttime": 5,
                    "phase": "bright"
                })
            },
            17 => {
                // Light Flicker (firelight)
                const min_light = find_min_surrounding_light(sec, sec["lightlevel"])
                door_thinkers.push({
                    "type": "flicker",
                    "sector": sec,
                    "maxlight": sec["lightlevel"],
                    "minlight": min_light,
                    "count": 4
                })
            },
            _ => {}
        }
    }
}

// ===========================================================================
// TELEPORTERS (p_telept.c)
// ===========================================================================

// Standard teleporter: moves player to teleport destination thing (type 14)
func ev_do_teleport(line) {
    const tag = line["tag"]
    // Find the destination sector(s) with matching tag
    let _tsi = 0
    while _tsi < len(map_sectors) {
        const sec = map_sectors[_tsi]
        _tsi = _tsi + 1
        if sec["tag"] != tag { continue }
        // Find teleport destination thing (doomednum 14) in this sector
        let _tti = 0
        while _tti < len(map_things) {
            const thing = map_things[_tti]
            _tti = _tti + 1
            if thing["type"] != 14 { continue }
            // Check if the thing is in the tagged sector
            const thing_ss = map_get_subsector(thing["x"], thing["y"])
            if thing_ss >= map_num_subsectors { continue }
            const thing_sector = map_subsectors[thing_ss]["sector"]
            if thing_sector != sec { continue }

            // Teleport the player
            const oldx = player_x
            const oldy = player_y
            player_x = thing["x"]
            player_y = thing["y"]
            player_z = player_floorz
            player_momx = 0
            player_momy = 0
            player_angle = thing["angle"] * 0x20000000 / 45

            // Update sector info
            const new_ss = map_get_subsector(player_x, player_y)
            if new_ss < map_num_subsectors {
                player_sector = map_subsectors[new_ss]["sector"]
                if player_sector != null {
                    player_floorz = player_sector["floorheight"]
                    player_ceilingz = player_sector["ceilingheight"]
                    player_z = player_floorz
                }
            }

            // Spawn teleport fog at source
            spawn_teleport_fog(oldx, oldy)
            // Spawn teleport fog at destination
            const dest_angle = thing["angle"] * 0x20000000 / 45
            const fog_x = player_x + 20 * FRACUNIT * fixed_to_int(fine_cosine(dest_angle)) / 65536
            const fog_y = player_y + 20 * FRACUNIT * fixed_to_int(fine_sine(dest_angle)) / 65536
            spawn_teleport_fog(fog_x, fog_y)

            sound_play("dstelept", player_x, player_y, 100)
            return
        }
    }
}

// Teleport monsters only (types 125, 126)
func ev_do_teleport_monsters_only(line) {
    // In single-player Doom, this only affects monsters, not the player.
    // Since our engine primarily handles player teleportation, this is a no-op
    // for the player. Monster teleportation would require tracking which mobj
    // triggered the line.
}

func spawn_teleport_fog(x, y) {
    // Visual effect placeholder -- in the full engine this spawns a BFG-style
    // fog sprite (MT_TFOG) at the given coordinates
    sound_play("dstelept", x, y, 50)
}

// ===========================================================================
// DONUT SPECIAL (p_spec.c: EV_DoDonut)
// ===========================================================================

// Type 9: the donut raises the inner (pool) sector to the outer ring height
// and changes the inner texture to match the outer ring.
func ev_do_donut(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _ddi = 0
    while _ddi < len(sectors) {
        const sec = sectors[_ddi]
        _ddi = _ddi + 1
        if sector_has_active_thinker(sec, "floor") { continue }

        // Find the outer ring: the sector on the other side of any 2-sided line
        let outer = null
        let outer_line = null
        let _ddj = 0
        while _ddj < len(map_linedefs) {
            const ld = map_linedefs[_ddj]
            _ddj = _ddj + 1
            if ld["frontsector"] == sec && ld["backsector"] != null {
                outer = ld["backsector"]
                outer_line = ld
            }
        }
        if outer == null { continue }

        // Find the donut ring model: sector on the other side of outer from the pool
        let model = null
        let _ddk = 0
        while _ddk < len(map_linedefs) {
            const ld = map_linedefs[_ddk]
            _ddk = _ddk + 1
            if ld["frontsector"] == outer && ld["backsector"] != null && ld["backsector"] != sec {
                model = ld["backsector"]
            }
            if ld["backsector"] == outer && ld["frontsector"] != null && ld["frontsector"] != sec {
                model = ld["frontsector"]
            }
        }
        if model == null { continue }

        // Raise the pool (inner sector) floor to the model height
        const target = model["floorheight"]
        door_thinkers.push({
            "type": "floor",
            "sector": sec,
            "speed": FLOORSPEED / 2,
            "target": target,
            "direction": 1,
            "crush": false,
            "new_floorpic": model["floorpic"],
            "change_texture": true,
            "change_special": 0
        })

        // Lower the outer ring floor to the model height
        door_thinkers.push({
            "type": "floor",
            "sector": outer,
            "speed": FLOORSPEED / 2,
            "target": target,
            "direction": if outer["floorheight"] > target { -1 } else { 1 },
            "crush": false,
            "change_texture": false
        })
    }
}

// ===========================================================================
// EXIT SPECIALS (p_spec.c)
// ===========================================================================

func ev_do_exit(line) {
    game_level_complete()
}

func ev_do_secret_exit(line) {
    player_secretcount = player_secretcount + 1
    game_level_complete()
}

// ===========================================================================
// THINKER EXECUTION (called every tic from game_ticker)
// ===========================================================================
func doors_run_thinkers() {
    let i = 0
    while i < len(door_thinkers) {
        const t = door_thinkers[i]
        let removed = false
        match t["type"] {
            "door"     => { removed = door_think(t, i) },
            "plat"     => { removed = plat_think(t, i) },
            "floor"    => { removed = floor_think(t, i) },
            "ceiling"  => { removed = ceiling_think(t, i) },
            "crusher"  => { removed = crusher_think(t, i) },
            "strobe"   => { strobe_think(t) },
            "glow"     => { glow_think(t) },
            "blink"    => { blink_think(t) },
            "flicker"  => { flicker_think(t) },
            _ => {}
        }
        if !removed { i = i + 1 }
    }
}

// ===========================================================================
// DOOR THINKER
// ===========================================================================
func door_think(t, idx) {
    const sector = t["sector"]

    if t["phase"] == "opening" {
        sector["ceilingheight"] = sector["ceilingheight"] + t["speed"]
        if sector["ceilingheight"] >= t["topheight"] {
            sector["ceilingheight"] = t["topheight"]
            if t["topcountdown"] > 0 {
                t["phase"] = "waiting"
                t["count"] = t["topcountdown"]
            } else if t["topcountdown"] == -1 {
                // Open stay -- remove thinker
                door_thinkers.splice(idx, 1)
                return true
            } else {
                // No wait -- start closing immediately
                t["phase"] = "closing"
            }
        }
    } else if t["phase"] == "waiting" {
        t["count"] = t["count"] - 1
        if t["count"] <= 0 {
            t["phase"] = "closing"
        }
    } else if t["phase"] == "closing" {
        sector["ceilingheight"] = sector["ceilingheight"] - t["speed"]
        if sector["ceilingheight"] <= sector["floorheight"] {
            sector["ceilingheight"] = sector["floorheight"]
            door_thinkers.splice(idx, 1)
            return true
        }
        // Check for player blockage -- reverse if blocked
        if player_sector == sector {
            if player_z + 56 * FRACUNIT > sector["ceilingheight"] {
                t["direction"] = 1
                t["phase"] = "opening"
            }
        }
    } else if t["phase"] == "closing_then_open" {
        // Close first, then wait, then open
        sector["ceilingheight"] = sector["ceilingheight"] - t["speed"]
        if sector["ceilingheight"] <= sector["floorheight"] {
            sector["ceilingheight"] = sector["floorheight"]
            t["phase"] = "waiting_to_open"
            t["count"] = t["topcountdown"]
        }
    } else if t["phase"] == "waiting_to_open" {
        t["count"] = t["count"] - 1
        if t["count"] <= 0 {
            t["phase"] = "opening"
            t["topcountdown"] = -1
        }
    }

    false
}

// ===========================================================================
// PLATFORM THINKER
// ===========================================================================
func plat_think(t, idx) {
    const sector = t["sector"]

    if t["status"] == "stopped" { return false }

    if t["phase"] == "down" {
        sector["floorheight"] = sector["floorheight"] - t["speed"]
        if sector["floorheight"] <= t["low"] {
            sector["floorheight"] = t["low"]
            t["phase"] = "wait"
            t["count"] = t["wait"]
        }
    } else if t["phase"] == "wait" {
        if t["count"] < 0 { return false }
        t["count"] = t["count"] - 1
        if t["count"] <= 0 {
            t["phase"] = "up"
        }
    } else if t["phase"] == "up" {
        sector["floorheight"] = sector["floorheight"] + t["speed"]
        if sector["floorheight"] >= t["high"] {
            sector["floorheight"] = t["high"]
            if t["perpetual"] == true {
                t["phase"] = "wait"
                t["count"] = t["wait"]
                // After wait, swap direction
                // We set a flag so wait knows to go down next
                t["next_phase"] = "down"
            } else {
                door_thinkers.splice(idx, 1)
                return true
            }
        }
    }

    // Handle perpetual platform cycling after wait
    if t["phase"] == "wait" && t["count"] <= 0 && t["perpetual"] == true {
        if t["next_phase"] == "down" {
            t["phase"] = "down"
            t["next_phase"] = null
        } else {
            t["phase"] = "up"
        }
    }

    false
}

// ===========================================================================
// FLOOR THINKER
// ===========================================================================
func floor_think(t, idx) {
    const sector = t["sector"]

    if t["direction"] > 0 {
        // Raising
        sector["floorheight"] = sector["floorheight"] + t["speed"]
        if sector["floorheight"] >= t["target"] {
            sector["floorheight"] = t["target"]
            if t["change_texture"] == true && t["new_floorpic"] != null {
                sector["floorpic"] = t["new_floorpic"]
                if t["change_special"] != null {
                    sector["special"] = t["change_special"]
                }
            }
            door_thinkers.splice(idx, 1)
            return true
        }
        // Crush check
        if t["crush"] == true {
            // Check if something is being crushed between floor and ceiling
            if sector["floorheight"] > sector["ceilingheight"] - 8 * FRACUNIT {
                // Something is crushed -- slow down
                if player_sector == sector {
                    player_damage(10, null)
                }
            }
        }
    } else {
        // Lowering
        sector["floorheight"] = sector["floorheight"] - t["speed"]
        if sector["floorheight"] <= t["target"] {
            sector["floorheight"] = t["target"]
            if t["change_texture"] == true && t["new_floorpic"] != null {
                sector["floorpic"] = t["new_floorpic"]
                if t["change_special"] != null {
                    sector["special"] = t["change_special"]
                }
            }
            door_thinkers.splice(idx, 1)
            return true
        }
    }

    false
}

// ===========================================================================
// CEILING THINKER
// ===========================================================================
func ceiling_think(t, idx) {
    const sector = t["sector"]

    if t["direction"] == -1 {
        // Lowering
        sector["ceilingheight"] = sector["ceilingheight"] - t["speed"]
        if sector["ceilingheight"] <= t["bottomheight"] {
            sector["ceilingheight"] = t["bottomheight"]
            door_thinkers.splice(idx, 1)
            return true
        }
    } else if t["direction"] == 1 {
        // Raising
        sector["ceilingheight"] = sector["ceilingheight"] + t["speed"]
        if sector["ceilingheight"] >= t["topheight"] {
            sector["ceilingheight"] = t["topheight"]
            door_thinkers.splice(idx, 1)
            return true
        }
    }

    false
}

// ===========================================================================
// CRUSHER THINKER
// ===========================================================================
func crusher_think(t, idx) {
    const sector = t["sector"]

    if t["direction"] == -1 {
        // Moving down (crushing)
        sector["ceilingheight"] = sector["ceilingheight"] - t["speed"]

        // Check for crush
        if sector["ceilingheight"] <= sector["floorheight"] + 8 * FRACUNIT {
            // We hit something or bottom
            if player_sector == sector && player_z + 56 * FRACUNIT > sector["ceilingheight"] {
                // Crush the player
                player_damage(10, null)
                // Slow down while crushing
                t["speed"] = CRUSHSPEED / 8
            }
        }

        if sector["ceilingheight"] <= t["bottomheight"] {
            sector["ceilingheight"] = t["bottomheight"]
            t["direction"] = 1
            t["speed"] = t["original_speed"]
        }
    } else if t["direction"] == 1 {
        // Moving up (returning)
        sector["ceilingheight"] = sector["ceilingheight"] + t["speed"]

        if sector["ceilingheight"] >= t["topheight"] {
            sector["ceilingheight"] = t["topheight"]
            if t["perpetual"] == true {
                t["direction"] = -1
            } else {
                door_thinkers.splice(idx, 1)
                return true
            }
        }
    }

    false
}

// ===========================================================================
// LIGHT THINKERS
// ===========================================================================

// Strobe light (blink on/off at set intervals)
func strobe_think(t) {
    t["count"] = t["count"] - 1
    if t["count"] > 0 { return }

    if t["phase"] == "bright" {
        t["sector"]["lightlevel"] = t["minlight"]
        t["count"] = t["darktime"]
        t["phase"] = "dark"
    } else {
        t["sector"]["lightlevel"] = t["maxlight"]
        t["count"] = t["brighttime"]
        t["phase"] = "bright"
    }
}

// Glowing light (smooth oscillation between min and max)
func glow_think(t) {
    const sector = t["sector"]
    if t["direction"] == -1 {
        // Dimming
        sector["lightlevel"] = sector["lightlevel"] - 2
        if sector["lightlevel"] <= t["minlight"] {
            sector["lightlevel"] = t["minlight"]
            t["direction"] = 1
        }
    } else {
        // Brightening
        sector["lightlevel"] = sector["lightlevel"] + 2
        if sector["lightlevel"] >= t["maxlight"] {
            sector["lightlevel"] = t["maxlight"]
            t["direction"] = -1
        }
    }
}

// Random blink (sector type 1)
func blink_think(t) {
    t["count"] = t["count"] - 1
    if t["count"] > 0 { return }

    if t["phase"] == "bright" {
        t["sector"]["lightlevel"] = t["minlight"]
        t["count"] = random_int(7) + 1
        t["phase"] = "dark"
    } else {
        t["sector"]["lightlevel"] = t["maxlight"]
        t["count"] = (random_int(7) + 1) * TICRATE
        t["phase"] = "bright"
    }
}

// Firelight flicker (sector type 17)
func flicker_think(t) {
    t["count"] = t["count"] - 1
    if t["count"] > 0 { return }

    const amount = (random_int(3) + 1) * 16
    if t["sector"]["lightlevel"] - amount < t["minlight"] {
        t["sector"]["lightlevel"] = t["minlight"]
    } else {
        t["sector"]["lightlevel"] = t["maxlight"]
    }
    t["count"] = 4
}

// ===========================================================================
// SECTOR DAMAGE (applied per-tic from sector specials)
// ===========================================================================
func doors_apply_sector_damage() {
    if player_sector == null { return }
    const special = player_sector["special"]
    if special == 0 { return }

    match special {
        4 => {
            // -20% damage every 32 tics (nukage)
            if game_level_time % 32 == 0 {
                if player_powers[pw_ironfeet] <= 0 {
                    player_damage(5, null)
                }
            }
        },
        5 => {
            // -10% damage (hellslime)
            if game_level_time % 32 == 0 {
                if player_powers[pw_ironfeet] <= 0 {
                    player_damage(10, null)
                }
            }
        },
        7 => {
            // -5% damage (nukage, mild)
            if game_level_time % 32 == 0 {
                if player_powers[pw_ironfeet] <= 0 {
                    player_damage(5, null)
                }
            }
        },
        9 => {
            // Secret sector (counted once)
            player_secretcount = player_secretcount + 1
            player_sector["special"] = 0
        },
        11 => {
            // -20% damage and exit level when health <= 10
            if game_level_time % 32 == 0 {
                if player_powers[pw_ironfeet] <= 0 {
                    player_damage(20, null)
                }
            }
            if player_health <= 10 {
                ev_do_exit(null)
            }
        },
        16 => {
            // -20% damage (super hellslime)
            if game_level_time % 32 == 0 {
                if player_powers[pw_ironfeet] <= 0 {
                    player_damage(20, null)
                }
            }
        },
        _ => {}
    }
}

// ===========================================================================
// SCROLLING TEXTURES (p_spec.c: animated walls/flats)
// ===========================================================================

// Animated flat list (original Doom animated floor/ceiling textures)
let anim_flats = []
let anim_walls = []
let anim_tic = 0

func doors_init_animations() {
    // Animated flats: each entry is [base_name, num_frames]
    anim_flats = [
        ["NUKAGE1", 3],   // NUKAGE1-3
        ["FWATER1", 4],   // FWATER1-4
        ["SWATER1", 4],   // SWATER1-4
        ["LAVA1", 4],     // LAVA1-4
        ["BLOOD1", 3],    // BLOOD1-3
        ["RROCK05", 4],   // RROCK05-08
        ["SLIME01", 4],   // SLIME01-04
        ["SLIME05", 4],   // SLIME05-08
        ["SLIME09", 4]    // SLIME09-12
    ]

    // Animated walls
    anim_walls = [
        ["BLODGR1", 4],   // BLODGR1-4
        ["BLODRIP1", 4],  // BLODRIP1-4
        ["FIREBLU1", 2],  // FIREBLU1-2
        ["FIRELAV3", 2],  // FIRELAV3, FIRELAVA
        ["FIREMAG1", 3],  // FIREMAG1-3
        ["FIREWALA", 3],  // FIREWALA-C
        ["GSTFONT1", 3],  // GSTFONT1-3
        ["ROCKRED1", 3],  // ROCKRED1-3
        ["SLADRIP1", 3],  // SLADRIP1-3
        ["WFALL1", 4],    // WFALL1-4
        ["DBRAIN1", 4]    // DBRAIN1-4
    ]
}

func doors_update_animations() {
    anim_tic = anim_tic + 1
    // Animation happens every 8 tics (roughly 4 times per second)
    if anim_tic % 8 != 0 { return }

    // Cycle animated flats in all sectors
    let _ani = 0
    while _ani < len(anim_flats) {
        const entry = anim_flats[_ani]
        _ani = _ani + 1
        const base = entry[0]
        const frames = entry[1]
        const frame = (anim_tic / 8) % frames
        const target_name = base.slice(0, len(base) - 1) + to_string(frame + 1)
        // In a full implementation, this would swap texture indices
    }
}

// ===========================================================================
// SCROLLING WALLS (type 48 -- special linedef flag)
// ===========================================================================
func doors_update_scrolling_walls() {
    let _swi = 0
    while _swi < len(map_linedefs) {
        const line = map_linedefs[_swi]
        _swi = _swi + 1
        if line["special"] == 48 {
            // Scroll texture left: adjust texture offset on front sidedef
            if line["front"] != null {
                line["front"]["textureoffset"] = line["front"]["textureoffset"] + FRACUNIT
            }
        }
    }
}

// ===========================================================================
// COMBINED TICK (called from doors_run_thinkers)
// Sector damage and animations are also handled here
// ===========================================================================
func doors_tick_extras() {
    doors_apply_sector_damage()
    doors_update_animations()
    doors_update_scrolling_walls()
}
