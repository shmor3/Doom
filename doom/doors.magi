func ev_do_plat_raise_next_change(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _pnci = 0
    while _pnci < len(sectors) {
        const sec = sectors[_pnci]
        _pnci = _pnci + 1
        if sector_has_active_thinker(sec, "floor") { continue }
        const target = find_next_highest_floor(sec, sec["floorheight"])
        const new_pic = get_floor_pic_from_line(line)
        door_thinkers.push({
            "type": "floor",
            "sector": sec,
            "speed": FLOORSPEED,
            "target": target,
            "direction": 1,
            "crush": false,
            "new_floorpic": new_pic,
            "change_texture": true,
            "change_special": 0
        })
    }
}

func get_floor_pic_from_line(line) {
    // Get floor texture from the front sector of the trigger line
    if line["frontsector"] != null {
        return line["frontsector"]["floorpic"]
    }
    ""
}

