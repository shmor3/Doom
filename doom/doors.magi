// Keyed door: normal speed, open-wait-close
func ev_do_locked_door(line, card1, card2, use_tag) {
    if !player_keys[card1] && !player_keys[card2] {
        hud_message_key(card1)
        return
    }
    ev_do_door_normal(line, use_tag)
}

// Keyed door: open stay
func ev_do_locked_door_open(line, card1, card2) {
    if !player_keys[card1] && !player_keys[card2] {
        hud_message_key(card1)
        return
    }
    ev_do_door_open(line, false)
}

// Keyed door: blazing (repeatable switch)
func ev_do_locked_door_blaze(line, card1, card2) {
    if !player_keys[card1] && !player_keys[card2] {
        hud_message_key(card1)
        return
    }
    ev_do_door_blaze_normal(line)
}

// Keyed door: blazing open stay (once switch)
func ev_do_locked_door_blaze_open(line, card1, card2) {
    if !player_keys[card1] && !player_keys[card2] {
        hud_message_key(card1)
        return
    }
    ev_do_door_blaze_open(line)
}

func hud_message_key(card) {
    match card {
        0 => println("You need a blue key to open this door."),   // it_bluecard
        1 => println("You need a yellow key to open this door."), // it_yellowcard
        2 => println("You need a red key to open this door."),    // it_redcard
        3 => println("You need a blue key to open this door."),   // it_blueskull
        4 => println("You need a yellow key to open this door."), // it_yellowskull
        5 => println("You need a red key to open this door."),    // it_redskull
        _ => println("You need a key to open this door.")
    }
}

// Core door creation for a sector
func do_door_for_sector(sector, speed, wait_tics) {
    // If door already active, reverse closing doors
    let _dfi = 0
    while _dfi < len(door_thinkers) {
        const t = door_thinkers[_dfi]
        _dfi = _dfi + 1
        if t["sector"] == sector && t["type"] == "door" {
            if t["direction"] == -1 {
                t["direction"] = 1
                t["phase"] = "opening"
            }
            return
        }
    }
    const top = find_lowest_ceiling_around(sector) - 4 * FRACUNIT
    door_thinkers.push({
        "type": "door",
        "sector": sector,
        "direction": 1,
        "speed": speed,
        "topheight": top,
        "topcountdown": wait_tics,
        "phase": "opening",
        "bottomheight": sector["floorheight"]
    })
}

// ===========================================================================
// LIFT / PLATFORM IMPLEMENTATIONS (p_plats.c)
// ===========================================================================

// Standard lift: floor lowers to lowest surrounding, waits, raises back
func ev_do_plat_down_wait_up(line, wait) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _pwi = 0
    while _pwi < len(sectors) {
        const sec = sectors[_pwi]
        _pwi = _pwi + 1
        if sector_has_active_thinker(sec, "plat") { continue }
        const low = find_lowest_floor_around(sec)
        door_thinkers.push({
            "type": "plat",
            "sector": sec,
            "speed": PLATSPEED * 4,
            "low": low,
            "high": sec["floorheight"],
            "wait": wait,
            "count": 0,
            "phase": "down",
            "crush": false,
            "status": "active",
            "tag": line["tag"]
        })
    }
}

// Blazing lift: same as above but faster
func ev_do_plat_down_wait_up_blaze(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _pbi = 0
    while _pbi < len(sectors) {
        const sec = sectors[_pbi]
        _pbi = _pbi + 1
        if sector_has_active_thinker(sec, "plat") { continue }
        const low = find_lowest_floor_around(sec)
        door_thinkers.push({
            "type": "plat",
            "sector": sec,
            "speed": PLATSPEED * 8,
            "low": low,
            "high": sec["floorheight"],
            "wait": PLATWAIT,
            "count": 0,
            "phase": "down",
            "crush": false,
            "status": "active",
            "tag": line["tag"]
        })
    }
}

// Perpetual platform: goes up and down forever
func ev_do_plat_perpetual_raise(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _pri = 0
    while _pri < len(sectors) {
        const sec = sectors[_pri]
        _pri = _pri + 1
        // Stop any existing perpetual plat first
        ev_stop_plat_for_sector(sec)
        const low = find_lowest_floor_around(sec)
        const high = find_highest_floor_around(sec)
        door_thinkers.push({
            "type": "plat",
            "sector": sec,
            "speed": PLATSPEED,
            "low": if low < sec["floorheight"] { low } else { sec["floorheight"] },
            "high": if high > sec["floorheight"] { high } else { sec["floorheight"] },
            "wait": PLATWAIT,
            "count": 0,
            "phase": "down",
            "crush": false,
            "status": "active",
            "perpetual": true,
            "tag": line["tag"]
        })
    }
}

// Stop platform
func ev_do_plat_stop(line) {
    let i = 0
    while i < len(door_thinkers) {
        const t = door_thinkers[i]
        if t["type"] == "plat" && t["tag"] == line["tag"] {
            t["status"] = "stopped"
            t["phase"] = "wait"
            t["count"] = -1
        }
        i = i + 1
    }
}

func ev_stop_plat_for_sector(sector) {
    let i = len(door_thinkers) - 1
    while i >= 0 {
        if door_thinkers[i]["type"] == "plat" && door_thinkers[i]["sector"] == sector {
            door_thinkers.splice(i, 1)
        }
        i = i - 1
    }
}

// Platform raise 24 units, change texture to surrounding
func ev_do_plat_raise_24_change(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _p24i = 0
    while _p24i < len(sectors) {
        const sec = sectors[_p24i]
        _p24i = _p24i + 1
        if sector_has_active_thinker(sec, "floor") { continue }
        const target = sec["floorheight"] + 24 * FRACUNIT
        const new_pic = get_floor_pic_from_line(line)
        door_thinkers.push({
            "type": "floor",
            "sector": sec,
            "speed": FLOORSPEED,
            "target": target,
            "direction": 1,
            "crush": false,
            "new_floorpic": new_pic,
            "change_texture": true,
            "change_special": 0
        })
    }
}

