// ===========================================================================
// CEILING IMPLEMENTATIONS (p_ceilng.c)
// ===========================================================================

// Ceiling lower to floor
func ev_do_ceiling_lower_to_floor(line) {
    const sectors = find_all_tagged_sectors(line["tag"])
    let _clfi = 0
    while _clfi < len(sectors) {
        const sec = sectors[_clfi]
        _clfi = _clfi + 1
        if sector_has_active_thinker(sec, "ceiling") { continue }
        const target = sec["floorheight"]
        door_thinkers.push({
            "type": "ceiling",
            "sector": sec,
            "speed": CEILSPEED,
            "target": target,
            "direction": -1,
            "crush": false,
            "bottomheight": target,
            "topheight": sec["ceilingheight"],
            "tag": line["tag"]
        })
    }
}

